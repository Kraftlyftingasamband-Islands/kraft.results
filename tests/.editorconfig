[*.cs]

# CA1062: Validate arguments of public methods
dotnet_diagnostic.CA1062.severity = none

# CA1515: Consider making public types internal
dotnet_diagnostic.CA1515.severity = none

# CA1707: Identifiers should not contain underscores
dotnet_diagnostic.CA1707.severity = none

# CA1816: Dispose methods should call SuppressFinalize
dotnet_diagnostic.CA1816.severity = none

# CA2234: Pass system uri objects instead of strings
dotnet_diagnostic.CA2234.severity = none

# CA1034: Nested types should not be visible (test constants use nested static classes for namespacing)
dotnet_diagnostic.CA1034.severity = none

# CA1716: Identifiers should not match keywords (domain names like User, Meet, Role conflict with VB keywords)
dotnet_diagnostic.CA1716.severity = none

# S2068: Credentials should not be hardcoded (test seed passwords are not real credentials)
dotnet_diagnostic.S2068.severity = none

# S3400: Methods should not return constants (test helpers may return constant values)
dotnet_diagnostic.S3400.severity = none

# CA1724: Type names should not match namespaces (test class names like Create, Equals naturally overlap)
dotnet_diagnostic.CA1724.severity = none
