@code {
    private bool _isOpen;

    private void ToggleNav() => _isOpen = !_isOpen;
    private void CloseNav() => _isOpen = false;
}

<button class="navbar-toggler @(_isOpen ? "is-open" : "")"
        @onclick="ToggleNav"
        aria-expanded="@_isOpen.ToString().ToLower()"
        aria-controls="main-nav"
        aria-label="@(_isOpen ? "Loka valmynd" : "Opna valmynd")">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
</button>

<div id="main-nav"
     class="nav-scrollable @(_isOpen ? "is-open" : "")"
     aria-hidden="@(!_isOpen).ToString().ToLower()">
    <nav class="nav" aria-label="Main navigation">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseNav">
                <span class="bi bi-house-nav-menu" aria-hidden="true"></span> Forsíða
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="meets" @onclick="CloseNav">
                <span class="bi bi-trophy-nav-menu" aria-hidden="true"></span> Mótaskrá
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="athletes" @onclick="CloseNav">
                <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Keppendur
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="team-competition" @onclick="CloseNav">
                <span class="bi bi-shield-nav-menu" aria-hidden="true"></span> Liðakeppni
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="rankings" @onclick="CloseNav">
                <span class="bi bi-bar-chart-line-nav-menu" aria-hidden="true"></span> Stigatöflur
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="records" @onclick="CloseNav">
                <span class="bi bi-medal-nav-menu" aria-hidden="true"></span> Met
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="teams" @onclick="CloseNav">
                <span class="bi bi-people-nav-menu" aria-hidden="true"></span> Félög
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="users" @onclick="CloseNav">
                        <span class="bi bi-gear-nav-menu" aria-hidden="true"></span> Notendur
                    </NavLink>
                </div>

                <div class="nav-separator"></div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="logout" @onclick="CloseNav">
                        <span class="bi bi-logout-nav-menu" aria-hidden="true"></span> Útskrá
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-separator"></div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="login" @onclick="CloseNav">
                        <span class="bi bi-login-nav-menu" aria-hidden="true"></span> Innskrá
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>

    <div class="sidebar-footer" aria-hidden="true">
        Kraftlyftingasamband Íslands
    </div>
</div>
