@page "/athletes"

@using KRAFT.Results.Contracts.Athletes
@using KRAFT.Results.Web.Services
@using Microsoft.AspNetCore.Components.Routing

@inject IApiService _apiService;

<h3>Keppendur</h3>

<table class="table">
    <thead>
        <tr>
            <th>Nafn</th>
        </tr>
    </thead>

    @foreach (AthleteSummary athlete in Athletes)
    {
        <tr>
            <td>
                <NavLink class="nav-link" href="@($"/athletes/{athlete.Slug}")">
                    @(athlete.YearOfBirth is null ? athlete.Name : $"{athlete.Name} ({athlete.YearOfBirth})")
                </NavLink>
            </td>
        </tr>
    }
</table>

@code {

    private IReadOnlyCollection<AthleteSummary> Athletes = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        Athletes = await _apiService.GetAsync<IReadOnlyCollection<AthleteSummary>>("/athletes") ?? [];
    }
}