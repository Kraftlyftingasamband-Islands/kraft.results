@using KRAFT.Results.Contracts.Meets
@using System.Text

<td class="@Border">
    <div class="@Classes">
        @(Attempt.Weight > 0 ? $"{Attempt.Weight}" : string.Empty)
    </div>
</td>

@code {
    [Parameter]
    [EditorRequired]
    public MeetAttempt Attempt { get; set; }

    private string Classes = string.Empty;
    private string Border = string.Empty;

    protected override void OnInitialized()
    {
        Border = Attempt.Round switch
        {
            1 => "border-start",
            3 => "border-end",
            _ => string.Empty,
        };

        if (Attempt.Weight == 0)
        {
            return;
        }

        StringBuilder stringBuilder = new("attempt-box ");

        if (Attempt.IsGood)
        {
            stringBuilder.Append(" good-lift");
        }
        else
        {
            stringBuilder.Append(" bad-lift");
        }

        if (Attempt.IsRecord)
        {
            stringBuilder.Append(" record");
        }

        Classes = stringBuilder.ToString();
    }
}