@using KRAFT.Results.Contracts.Meets
@using System.Text

<td class="@Border">
    <div class="rounded-box">
        <div class="side discipline-round">
            @Attempt.Discipline[0]@Attempt.Round
        </div>

        <div class="@Classes">
            @Value
        </div>
    </div>
</td>

@code {
    [Parameter]
    [EditorRequired]
    public MeetAttempt Attempt { get; init; }

    private string Classes = string.Empty;
    private string Border = string.Empty;
    private string Value = "-";

    protected override void OnInitialized()
    {
        Border = Attempt.Round switch
        {
            1 => "border-start",
            3 => "border-end",
            _ => string.Empty,
        };

        StringBuilder stringBuilder = new("side");

        if (Attempt.Weight == 0)
        {
            Classes = " skipped";
            return;
        }

        stringBuilder.Append(" attempt");

        Value = $"{Attempt.Weight:F1}";

        if (Attempt.IsGood)
        {
            stringBuilder.Append(" good");
        }
        else
        {
            stringBuilder.Append(" bad");
        }

        if (Attempt.IsRecord)
        {
            stringBuilder.Append(" record");
        }

        Classes = stringBuilder.ToString();
    }
}