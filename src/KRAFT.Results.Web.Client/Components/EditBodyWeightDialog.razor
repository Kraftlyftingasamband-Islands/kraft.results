@inject IJSRuntime JSRuntime
@using System.Globalization

<dialog id="@Id" role="dialog" aria-labelledby="@($"{Id}-title")" @oncancel="HandleCancel">
    <form class="edit-dialog-content" @onsubmit="HandleSave">
        <h2 id="@($"{Id}-title")" class="edit-dialog-title">Breyta líkamsþyngd</h2>
        <p class="edit-dialog-context">@AthleteName</p>

        <div class="edit-dialog-field">
            <label class="form-label" for="@($"{Id}-input")">Líkamsþyngd (kg)</label>
            <input id="@($"{Id}-input")"
                   class="form-input"
                   type="text"
                   inputmode="decimal"
                   autocomplete="off"
                   aria-describedby="@(!string.IsNullOrEmpty(ErrorMessage) ? $"{Id}-error" : null)"
                   @bind="Weight"
                   @bind:culture="CultureInfo.CurrentCulture"
                   @bind:event="oninput"
                   autofocus />
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div id="@($"{Id}-error")" class="edit-dialog-error" role="alert">@ErrorMessage</div>
        }

        <div class="edit-dialog-actions">
            <button type="submit"
                    class="btn-action"
                    disabled="@(Weight <= 0 || IsLoading)"
                    aria-busy="@IsLoading">
                @if (IsLoading)
                {
                    <span class="btn-spinner" aria-hidden="true"></span>
                }
                else
                {
                    <span>Vista</span>
                }
            </button>
            <button type="button" class="edit-dialog-cancel" @onclick="HandleCancel" disabled="@IsLoading">Hætta við</button>
        </div>
    </form>
</dialog>

@code {
    [Parameter, EditorRequired]
    public string Id { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string AthleteName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public decimal CurrentWeight { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<decimal> OnSave { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    private decimal Weight { get; set; }

    public async Task ShowAsync()
    {
        Weight = CurrentWeight;
        await InvokeAsync(StateHasChanged);
        await JSRuntime.InvokeVoidAsync("Kraftresults.showDialog", Id);
        await JSRuntime.InvokeVoidAsync("Kraftresults.selectInput", $"{Id}-input");
    }

    public async Task CloseAsync()
    {
        await JSRuntime.InvokeVoidAsync("Kraftresults.closeDialog", Id);
    }

    private async Task HandleSave()
    {
        await OnSave.InvokeAsync(Weight);
    }

    private async Task HandleCancel()
    {
        await CloseAsync();
    }
}