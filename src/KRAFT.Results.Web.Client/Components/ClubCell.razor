<td>
    <div class="@Classes">
        <NavLink class="nav-link" href="@Link">
            @Club
        </NavLink>
    </div>
</td>

@code {
    [Parameter]
    [EditorRequired]
    public string Club { get; set; }

    [Parameter]
    [EditorRequired]
    public string Slug { get; init; }

    private string Classes = string.Empty;
    private string? Link;

    protected override void OnInitialized()
    {
        Classes = "rounded-box";

        if (string.IsNullOrWhiteSpace(Club))
        {
            Club = "-";
            return;
        }

        Link = $"/teams/{Slug}";
    }
}