@using KRAFT.Results.Contracts.Meets

@if (OnClick.HasDelegate)
{
    <button class="@_classes pill-clickable" tabindex="0" aria-label="@_ariaLabel" aria-describedby="@_tooltipId" @onclick="OnClick" @onmousedown:preventDefault>
        @_value
        @if (Attempt.IsRecord && Attempt.IsGood && RecordContext is not null)
        {
            <span id="@_tooltipId" class="tip" role="tooltip">@RecordContext</span>
        }
        else if (Attempt.IsPendingRecord && Attempt.IsGood)
        {
            <span id="@_tooltipId" class="tip" role="tooltip">Met til staðfestingar</span>
        }
    </button>
}
else
{
    <span class="@_classes" tabindex="@_tabIndex" role="@_role" aria-label="@_ariaLabel" aria-describedby="@_tooltipId">
        @_value
        @if (Attempt.IsRecord && Attempt.IsGood && RecordContext is not null)
        {
            <span id="@_tooltipId" class="tip" role="tooltip">@RecordContext</span>
        }
        else if (Attempt.IsPendingRecord && Attempt.IsGood)
        {
            <span id="@_tooltipId" class="tip" role="tooltip">Met til staðfestingar</span>
        }
    </span>
}

@code {
    [Parameter, EditorRequired]
    public MeetAttempt Attempt { get; init; } = null!;

    [Parameter]
    public string? RecordContext { get; init; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string _classes = string.Empty;
    private string _value = "–";
    private string? _tabIndex;
    private string? _role;
    private string? _ariaLabel;
    private string? _tooltipId;

    protected override void OnParametersSet()
    {
        if (Attempt.Weight == 0)
        {
            _classes = "pill pill-skipped";
            _tabIndex = null;
            _role = null;
            _ariaLabel = null;
            _tooltipId = null;
            return;
        }

        _value = $"{Attempt.Weight:F1}";

        if (Attempt.IsGood && Attempt.IsRecord)
        {
            _classes = "pill pill-record";
            _tabIndex = "0";
            _role = "img";
            _ariaLabel = $"{_value} kg \u2013 Met";
            _tooltipId = $"tip-{Guid.NewGuid():N}";
        }
        else if (Attempt.IsGood && Attempt.IsPendingRecord)
        {
            _classes = "pill pill-pending";
            _tabIndex = "0";
            _role = "img";
            _ariaLabel = $"{_value} kg \u2013 Met til sta\u00f0festingar";
            _tooltipId = $"tip-{Guid.NewGuid():N}";
        }
        else if (Attempt.IsGood)
        {
            _classes = "pill pill-good";
            _tabIndex = null;
            _role = null;
            _ariaLabel = null;
            _tooltipId = null;
        }
        else
        {
            _classes = "pill pill-bad";
            _tabIndex = null;
            _role = null;
            _ariaLabel = null;
            _tooltipId = null;
        }
    }
}