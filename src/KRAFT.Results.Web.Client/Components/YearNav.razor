<nav class="year-nav" aria-label="Velja ár">
    @if (MinYear.HasValue && Year <= MinYear.Value)
    {
        <span class="year-btn year-btn-disabled" aria-disabled="true" aria-label="Fyrra ár">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/>
            </svg>
        </span>
    }
    else
    {
        <a class="year-btn" href="@($"{BaseUrl}/{Year - 1}")" aria-label="Fyrra ár">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/>
            </svg>
        </a>
    }

    <div class="year-display">
        <span class="year-label">@Label</span>
        <span class="year-value">@Year</span>
    </div>

    @if (MaxYear.HasValue && Year >= MaxYear.Value)
    {
        <span class="year-btn year-btn-disabled" aria-disabled="true" aria-label="Næsta ár">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
            </svg>
        </span>
    }
    else
    {
        <a class="year-btn" href="@($"{BaseUrl}/{Year + 1}")" aria-label="Næsta ár">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
            </svg>
        </a>
    }
</nav>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter, EditorRequired]
    public int Year { get; set; }

    [Parameter, EditorRequired]
    public string BaseUrl { get; set; } = "";

    [Parameter]
    public int? MinYear { get; set; }

    [Parameter]
    public int? MaxYear { get; set; }
}
