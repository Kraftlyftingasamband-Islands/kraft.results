<td>
    <div class="rank-cell">
        <span class="medal @MedalClass" aria-hidden="true"></span>
        <span class="rank-number">@Value</span>
    </div>
</td>

@code {
    [Parameter]
    [EditorRequired]
    public int Rank { get; init; }

    public string Value { get; private set; } = "-";

    public string MedalClass { get; private set; } = string.Empty;

    protected override void OnInitialized()
    {
        MedalClass = Rank switch
        {
            1 => "gold",
            2 => "silver",
            3 => "bronze",
            _ => string.Empty,
        };

        if (Rank > 0 && Rank < int.MaxValue - 1)
        {
            Value = Rank.ToString();
        }
    }
}
