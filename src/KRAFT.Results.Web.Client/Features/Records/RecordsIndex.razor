@page "/records"

@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Eras
@using KRAFT.Results.Web.Client.Components

@inject HttpClient HttpClient

<PageTitle>Met</PageTitle>

<h1>Met</h1>

<RecordsToolbar Eras="@(_eras ?? new List<EraSummary>())"
                CurrentEraSlug="@_currentEraSlug"
                OnEquipmentTypeChanged="HandleEquipmentTypeChanged"
                OnEraChanged="HandleEraChanged" />

@if (_erasLoadFailed)
{
    <p class="era-load-error">Ekki tókst að sækja tímabilsgögn.</p>
}

<section class="gender-section">
    <h2>@("m".ToGenderGroupLabel())</h2>
    <div class="category-grid">
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "open")">@GetCardLabel("open", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "subjunior")">@GetCardLabel("subjunior", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "junior")">@GetCardLabel("junior", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "masters1")">@GetCardLabel("masters1", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "masters2")">@GetCardLabel("masters2", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "masters3")">@GetCardLabel("masters3", "m")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("m", "masters4")">@GetCardLabel("masters4", "m")</NavLink>
        </Card>
    </div>
</section>

<section class="gender-section">
    <h2>@("f".ToGenderGroupLabel())</h2>
    <div class="category-grid">
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "open")">@GetCardLabel("open", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "subjunior")">@GetCardLabel("subjunior", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "junior")">@GetCardLabel("junior", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "masters1")">@GetCardLabel("masters1", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "masters2")">@GetCardLabel("masters2", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "masters3")">@GetCardLabel("masters3", "f")</NavLink>
        </Card>
        <Card>
            <NavLink class="card-link" href="@GetRecordUrl("f", "masters4")">@GetCardLabel("masters4", "f")</NavLink>
        </Card>
    </div>
</section>

@code {
    private string _equipmentType = "classic";
    private List<EraSummary>? _eras;
    private string _eraSlug = "";
    private string _currentEraSlug = "";
    private bool _erasLoadFailed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _eras = await HttpClient.GetFromJsonAsync<List<EraSummary>>("/eras");
            _erasLoadFailed = false;

            if (_eras is not null && _eras.Count > 0)
            {
                _currentEraSlug = _eras[^1].Slug;
                _eraSlug = _currentEraSlug;

                EraSummary? initialEra = _eras.Find(e => e.Slug == _eraSlug);
                if (initialEra is not null)
                {
                    if (initialEra.HasClassicRecords && !initialEra.HasEquippedRecords)
                    {
                        _equipmentType = "classic";
                    }
                    else if (!initialEra.HasClassicRecords && initialEra.HasEquippedRecords)
                    {
                        _equipmentType = "equipped";
                    }
                }
            }
        }
        catch
        {
            _eras = null;
            _erasLoadFailed = true;
        }
    }

    private Task HandleEquipmentTypeChanged(string type)
    {
        _equipmentType = type;
        return Task.CompletedTask;
    }

    private Task HandleEraChanged(string slug)
    {
        _eraSlug = slug;
        return Task.CompletedTask;
    }

    private static string GetCardLabel(string slug, string gender)
    {
        string label = slug.ToAgeCategoryLabel(gender);
        string range = slug.ToAgeCategoryAgeRange();
        return range.Length > 0 ? $"{label} ({range})" : label;
    }

    private string GetRecordUrl(string gender, string ageCategory)
    {
        string url = $"records/{gender}/{ageCategory}?equipmentType={_equipmentType}";

        if (_eraSlug != _currentEraSlug)
        {
            url += $"&era={_eraSlug}";
        }

        return url;
    }
}