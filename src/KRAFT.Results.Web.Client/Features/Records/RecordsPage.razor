@page "/records/{Gender}/{AgeCategory}"

@using KRAFT.Results.Contracts.Eras
@using KRAFT.Results.Contracts.Records
@using KRAFT.Results.Web.Client.Components

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<PageTitle>Met - @(_selectedEra is not null && _selectedEra.Slug != _currentEraSlug ? $"{_selectedEra.Title} - " : "")@GenderLabel - @AgeCategory</PageTitle>

<nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
        <li>
            <NavLink class="breadcrumb-link" href="records">Met</NavLink>
        </li>
        @if (_selectedEra is not null && _selectedEra.Slug != _currentEraSlug)
        {
            <li>@_selectedEra.Title</li>
        }
        <li>@GenderLabel</li>
        <li aria-current="page">@AgeCategory</li>
    </ol>
</nav>

<h1>@GenderLabel - @AgeCategory</h1>

<RecordsToolbar Eras="@(_eras ?? new List<EraSummary>())"
                CurrentEraSlug="@_currentEraSlug"
                InitialEquipmentType="@_equipmentType"
                InitialEraSlug="@_eraSlug"
                Disabled="_isLoading"
                OnEquipmentTypeChanged="HandleEquipmentTypeChanged"
                OnEraChanged="HandleEraChanged" />

@if (_isLoading)
{
    <div class="spinner-container" role="status">
        <div class="spinner"></div>
        <span class="visually-hidden">Sæki met...</span>
    </div>
}
else if (_hasError)
{
    <div class="error-state" role="alert">
        <p>Villa kom upp. Reyndu aftur.</p>
        <button class="retry-btn" @onclick="LoadDataAsync">Reyna aftur</button>
    </div>
}
else if (_groups is not null && _groups.Count > 0)
{
    @foreach (RecordGroup group in _groups)
    {
        <section class="record-section">
            <h2>@group.Category</h2>
            <div class="table-wrapper" tabindex="0" role="region" aria-label="@group.Category met">
                <table aria-label="@group.Category">
                    <colgroup>
                        <col class="col-weight-category" />
                        <col class="col-athlete" />
                        <col class="col-birthyear" />
                        <col class="col-club" />
                        <col class="col-bodyweight" />
                        <col class="col-mark" />
                        <col class="col-date" />
                        <col class="col-meet" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th scope="col" aria-label="Flokkur">Fl.</th>
                            <th scope="col">Nafn</th>
                            <th scope="col" class="text-center hide-mobile" aria-label="Fæðingarár">F.ár</th>
                            <th scope="col" class="hide-mobile">Félag</th>
                            <th scope="col" class="text-end" aria-label="Líkamsþyngd">Líkamsþ.</th>
                            <th scope="col" class="text-end">Mark</th>
                            <th scope="col" aria-label="Dagsetning">Dags.</th>
                            <th scope="col">Mót</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (RecordEntry record in group.Records)
                        {
                            <tr class="@(record.IsStandard ? "standard-row" : "")">
                                <td class="weight-category-cell">@record.WeightCategory</td>
                                @if (record.IsStandard)
                                {
                                    <td colspan="7" class="standard-cell">Íslenski staðallinn</td>
                                }
                                else
                                {
                                    <td>
                                        @if (record.AthleteSlug is not null)
                                        {
                                            <NavLink class="nav-link" href="@($"athletes/{record.AthleteSlug}")">
                                                @record.Athlete
                                            </NavLink>
                                        }
                                        else
                                        {
                                            @record.Athlete
                                        }
                                    </td>
                                    <td class="text-center hide-mobile numeric-value">@(record.BirthYear?.ToString() ?? "-")</td>
                                    <td class="hide-mobile">@(record.Club ?? "-")</td>
                                    <td class="text-end numeric-value">@(record.BodyWeight?.ToString("F1") ?? "-")</td>
                                    <td class="text-end numeric-value">@record.Weight.ToString("F1")</td>
                                    <td class="numeric-value">@record.Date.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (record.MeetSlug is not null)
                                        {
                                            <NavLink class="nav-link" href="@($"meets/{record.MeetSlug}")">
                                                @record.Meet
                                            </NavLink>
                                        }
                                        else
                                        {
                                            @record.Meet
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
}
else
{
    <div class="empty-state">
        Engin met fundust.
    </div>
}

@code {
    [Parameter]
    public string Gender { get; set; } = default!;

    [Parameter]
    public string AgeCategory { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "equipmentType")]
    public string? EquipmentType { get; set; }

    [SupplyParameterFromQuery(Name = "era")]
    public string? Era { get; set; }

    private string _equipmentType = "classic";
    private string _eraSlug = "";
    private string _currentEraSlug = "";
    private List<EraSummary>? _eras;
    private EraSummary? _selectedEra;
    private bool _isLoading = true;
    private bool _hasError;
    private List<RecordGroup>? _groups;

    private string GenderLabel => Gender?.ToLowerInvariant() switch
    {
        "m" => "Karlar",
        "f" => "Konur",
        _ => Gender ?? "",
    };

    protected override async Task OnInitializedAsync()
    {
        _equipmentType = EquipmentType ?? "classic";

        try
        {
            _eras = await HttpClient.GetFromJsonAsync<List<EraSummary>>("/eras");

            if (_eras is not null && _eras.Count > 0)
            {
                _currentEraSlug = _eras[^1].Slug;
                _eraSlug = Era ?? _currentEraSlug;
                _selectedEra = _eras.FirstOrDefault(e => e.Slug == _eraSlug);

                EraSummary? initialEra = _eras?.Find(e => e.Slug == _eraSlug);
                if (initialEra is not null)
                {
                    if (initialEra.HasClassicRecords && !initialEra.HasEquippedRecords)
                    {
                        _equipmentType = "classic";
                    }
                    else if (!initialEra.HasClassicRecords && initialEra.HasEquippedRecords)
                    {
                        _equipmentType = "equipped";
                    }
                }
            }
        }
        catch
        {
            _eras = null;
        }

        await LoadDataAsync();
    }

    private Task HandleEraChanged(string slug)
    {
        _eraSlug = slug;
        _selectedEra = _eras?.FirstOrDefault(e => e.Slug == _eraSlug);
        return Task.CompletedTask;
    }

    private async Task HandleEquipmentTypeChanged(string type)
    {
        _equipmentType = type;
        UpdateUrl(replace: true);
        await LoadDataAsync();
    }

    private void UpdateUrl(bool replace)
    {
        Dictionary<string, object?> queryParams = new()
        {
            ["equipmentType"] = _equipmentType,
            ["era"] = _eraSlug,
        };

        string url = NavigationManager.GetUriWithQueryParameters(
            $"/records/{Gender}/{AgeCategory}",
            queryParams);

        NavigationManager.NavigateTo(url, replace: replace);
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _hasError = false;

        try
        {
            string url = $"/records?gender={Uri.EscapeDataString(Gender)}&ageCategory={Uri.EscapeDataString(AgeCategory)}&equipmentType={Uri.EscapeDataString(_equipmentType)}";

            if (!string.IsNullOrEmpty(_eraSlug))
            {
                url += $"&era={Uri.EscapeDataString(_eraSlug)}";
            }

            _groups = await HttpClient.GetFromJsonAsync<List<RecordGroup>>(url);
        }
        catch
        {
            _hasError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
