@using KRAFT.Results.Contracts.TeamCompetition

<div class="sc-card @(_isFirst ? "sc-card-first" : null)">
    <div class="sc-rank @_rankClass">
        @_rankDisplay
    </div>
    <div class="sc-name-col">
        @if (!string.IsNullOrEmpty(Standing.TeamSlug))
        {
            <NavLink class="sc-team-abbr" href="@($"/teams/{Standing.TeamSlug}")">@Standing.TeamTitleShort</NavLink>
        }
        else
        {
            <span class="sc-team-abbr">@Standing.TeamTitleShort</span>
        }
        <span class="sc-team-name">@Standing.TeamName</span>
    </div>
    <div class="sc-points">
        <span class="sc-points-label">Stig</span>
        @Standing.TotalPoints
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TeamCompetitionStanding Standing { get; init; } = null!;

    private bool _isFirst;
    private string _rankDisplay = string.Empty;
    private string _rankClass = string.Empty;

    protected override void OnParametersSet()
    {
        _isFirst = Standing.Rank == 1;
        _rankDisplay = Standing.Rank switch
        {
            1 => "\U0001f947",
            2 => "\U0001f948",
            3 => "\U0001f949",
            _ when Standing.Rank > 0 => Standing.Rank.ToString(),
            _ => "\u2013",
        };
        _rankClass = Standing.Rank is 1 or 2 or 3 ? "rank-medal" : string.Empty;
    }
}
