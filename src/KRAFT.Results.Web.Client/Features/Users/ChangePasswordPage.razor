@page "/change-password"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using System.Net
@using KRAFT.Results.Contracts.Users
@using KRAFT.Results.Web.Client.Features.Auth

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject TokenStorageService TokenStorage

<PageTitle>Breyta lykilorði</PageTitle>
<h3>Breyta lykilorði</h3>

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="change-password">
        <DataAnnotationsValidator />

        <div class="form-field">
            <label class="form-label" for="current-password">Núverandi lykilorð</label>
            <InputText type="password"
                       id="current-password"
                       class="form-input"
                       autocomplete="current-password"
                       aria-describedby="@(HasError ? "change-password-error" : null)"
                       @bind-Value="_model.CurrentPassword"
                       disabled="@_isLoading" />
            <ValidationMessage For="@(() => _model.CurrentPassword)" />
        </div>

        <div class="form-field">
            <label class="form-label" for="new-password">Nýtt lykilorð</label>
            <InputText type="password"
                       id="new-password"
                       class="form-input"
                       autocomplete="new-password"
                       aria-describedby="@(HasError ? "change-password-error" : null)"
                       @bind-Value="_model.NewPassword"
                       disabled="@_isLoading" />
            <ValidationMessage For="@(() => _model.NewPassword)" />
        </div>

        <div class="form-field">
            <label class="form-label" for="confirm-password">Staðfesta nýtt lykilorð</label>
            <InputText type="password"
                       id="confirm-password"
                       class="form-input"
                       autocomplete="new-password"
                       aria-describedby="@(HasError ? "change-password-error" : null)"
                       @bind-Value="_model.ConfirmNewPassword"
                       disabled="@_isLoading" />
            <ValidationMessage For="@(() => _model.ConfirmNewPassword)" />
        </div>

        <div class="form-actions">
            <SubmitButton Label="Breyta lykilorði" IsLoading="@_isLoading" />

            <a href="/" class="btn-cancel">Til baka</a>
        </div>

        @if (_successMessage is not null)
        {
            <p class="success-message" role="status">@_successMessage</p>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <ErrorMessage Id="change-password-error" Message="@_errorMessage" />
        }
    </EditForm>
</div>

@code {
    private readonly ChangePasswordModel _model = new();
    private bool _isLoading;
    private string? _errorMessage;
    private string? _successMessage;

    private bool HasError => !string.IsNullOrEmpty(_errorMessage);

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            ChangePasswordCommand command = new(
                _model.CurrentPassword,
                _model.NewPassword,
                _model.ConfirmNewPassword);

            HttpResponseMessage response = await HttpClient.PostAsJsonAsync("/users/change-password", command);

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                await TokenStorage.RemoveTokenAsync();
                AuthStateProvider.MarkUserAsLoggedOut();
                NavigationManager.NavigateTo("/login");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                Contracts.ErrorResponse? error = await response.Content.ReadFromJsonAsync<Contracts.ErrorResponse>();

                _errorMessage = error?.Code switch
                {
                    "Users.IncorrectCurrentPassword" => "Rangt núverandi lykilorð.",
                    "Users.PasswordsDoNotMatch" => "Nýju lykilorðin passa ekki saman.",
                    "Password.Empty" => "Lykilorð má ekki vera tómt.",
                    _ => "Villa kom upp. Reyndu aftur síðar.",
                };
                return;
            }

            await TokenStorage.RemoveTokenAsync();
            AuthStateProvider.MarkUserAsLoggedOut();
            NavigationManager.NavigateTo("/login");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed class ChangePasswordModel
    {
        [Required(ErrorMessage = "Núverandi lykilorð er nauðsynlegt.")]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Nýtt lykilorð er nauðsynlegt.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Staðfesting lykilorðs er nauðsynleg.")]
        public string ConfirmNewPassword { get; set; } = string.Empty;
    }
}