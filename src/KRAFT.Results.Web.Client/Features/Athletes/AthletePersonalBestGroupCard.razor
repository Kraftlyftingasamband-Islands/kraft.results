@using System.Globalization
@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes

<div class="pbg-card">
    <h3 class="pbg-header">@Title</h3>
    <div class="pbg-rows">
        @foreach (AthletePersonalBest best in PersonalBests)
        {
            string disciplineLabel = best.Discipline.ToDisplayName() is { Length: > 0 } name
                ? name
                : Constants.Total;

            List<AthleteRecord> matchingRecords = MatchingRecords(best);
            string recordSuffix = matchingRecords.Count > 0
                ? " — " + string.Join(", ", matchingRecords.Select(r => $"Íslandsmet ({r.AgeCategory})"))
                : string.Empty;
            string ariaLabel = $"{disciplineLabel} — {best.Weight.ToString("F1", CultureInfo.InvariantCulture)} kg{recordSuffix}";

            <a class="pbg-row @(best.Discipline == Discipline.None ? "pbg-row--total" : "")"
               href="@SlugSanitizer.SlugHref("/meets/", best.MeetSlug)"
               aria-label="@ariaLabel">
                <div class="pbg-left">
                    <span class="pbg-discipline">
                        @if (best.IsSingleLift)
                        {
                            <span class="pbg-sl-badge">@Constants.SingeLift</span>
                        }
                        @disciplineLabel
                    </span>
                    <span class="pbg-meta">@best.Date.ToString("dd.MM.yyyy") · @best.BodyWeight.ToString("F1", CultureInfo.InvariantCulture) kg</span>
                </div>
                <div class="pbg-right">
                    @if (matchingRecords.Count > 0)
                    {
                        <div class="pbg-stars" aria-hidden="true">
                            @foreach (AthleteRecord record in matchingRecords)
                            {
                                <span class="pbg-star"
                                      data-tooltip="@($"Íslandsmet · {record.AgeCategory} · {record.WeightCategory}")">★</span>
                            }
                        </div>
                    }
                    <span class="pbg-weight">@best.Weight.ToString("F1", CultureInfo.InvariantCulture) <span class="pbg-unit">kg</span></span>
                </div>
            </a>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<AthletePersonalBest> PersonalBests { get; set; } = [];

    [Parameter]
    public IReadOnlyList<AthleteRecord> Records { get; set; } = [];

    private static string DisciplineType(AthletePersonalBest best)
    {
        return best.Discipline == Discipline.None
            ? Constants.Total
            : best.Discipline.ToDisplayName();
    }

    private List<AthleteRecord> MatchingRecords(AthletePersonalBest best)
    {
        string type = DisciplineType(best);
        return Records.Where(r =>
            r.Weight == best.Weight &&
            r.IsClassic == best.IsClassic &&
            r.IsSingleLift == best.IsSingleLift &&
            r.Type == type)
            .ToList();
    }
}
