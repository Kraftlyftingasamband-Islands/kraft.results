@using System.Globalization
@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes

<a class="apb-card-link" href="@($"/meets/{Best.MeetSlug}")" aria-label="@_disciplineLabel — @Best.Weight.ToString("F1", CultureInfo.InvariantCulture) kg">
    <div class="apb-card">
        <div class="apb-badge">
            @switch (Best.Discipline)
            {
                case Discipline.Squat:
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="15" cy="4" r="2"/>
                        <line x1="6" y1="8.5" x2="20" y2="8.5"/>
                        <line x1="14" y1="6" x2="11" y2="12"/>
                        <line x1="11" y1="12" x2="7" y2="17"/>
                        <line x1="11" y1="12" x2="15" y2="17"/>
                        <line x1="7" y1="17" x2="9" y2="22"/>
                        <line x1="15" y1="17" x2="13" y2="22"/>
                    </svg>
                    break;
                case Discipline.Bench:
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="20" cy="15" r="2"/>
                        <line x1="4" y1="17" x2="18" y2="17"/>
                        <line x1="2" y1="19" x2="22" y2="19"/>
                        <line x1="11" y1="17" x2="11" y2="9"/>
                        <line x1="6" y1="9" x2="16" y2="9"/>
                        <line x1="6" y1="7" x2="6" y2="11"/>
                        <line x1="16" y1="7" x2="16" y2="11"/>
                    </svg>
                    break;
                case Discipline.Deadlift:
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="18" cy="5" r="2"/>
                        <line x1="16" y1="7" x2="8" y2="13"/>
                        <line x1="11" y1="11" x2="11" y2="19"/>
                        <line x1="8" y1="13" x2="7" y2="21"/>
                        <line x1="8" y1="13" x2="14" y2="21"/>
                        <line x1="3" y1="19" x2="19" y2="19"/>
                        <line x1="3" y1="17" x2="3" y2="21"/>
                        <line x1="19" y1="17" x2="19" y2="21"/>
                    </svg>
                    break;
                default:
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="2" y1="12" x2="22" y2="12"/>
                        <line x1="3" y1="8" x2="3" y2="16"/>
                        <line x1="21" y1="8" x2="21" y2="16"/>
                        <line x1="6" y1="9.5" x2="6" y2="14.5"/>
                        <line x1="18" y1="9.5" x2="18" y2="14.5"/>
                    </svg>
                    break;
            }
        </div>
        <div class="apb-name-col">
            <span class="apb-label">
                @if (Best.IsSingleLift)
                {
                    <span class="apb-sl-badge">@Constants.SingeLift</span>
                }
                @_disciplineLabel
            </span>
            <span class="apb-meta">@Best.Date.ToString("dd.MM.yyyy") · @Best.BodyWeight.ToString("F1", CultureInfo.InvariantCulture) kg</span>
        </div>
        <div class="apb-mark-col">
            <span class="apb-weight">@Best.Weight.ToString("F1", CultureInfo.InvariantCulture) <span class="apb-unit">kg</span></span>
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired]
    public AthletePersonalBest Best { get; set; } = null!;

    private string _disciplineLabel = string.Empty;

    protected override void OnParametersSet()
    {
        _disciplineLabel = Best.Discipline.ToDisplayName() is { Length: > 0 } name
            ? name
            : Constants.Total;
    }
}
