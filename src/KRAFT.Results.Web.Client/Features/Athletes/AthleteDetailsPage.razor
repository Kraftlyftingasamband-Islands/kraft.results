@page "/athletes/{slug}"

@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes
@using KRAFT.Results.Web.Client.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<div class="page-header">
    <h1>@Athlete?.Name</h1>
    <AuthorizeView Roles="Admin">
        <div class="admin-actions">
            <a href="/athletes/@Slug/edit" class="btn-action" aria-label="Breyta keppanda">
                <svg class="btn-icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                    <path d="m15 5 4 4"/>
                </svg>
                Breyta
            </a>
            <button class="btn-action btn-danger" aria-label="Eyða keppanda" @onclick="ShowDeleteDialog">
                <svg class="btn-icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18"/>
                    <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                    <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                    <line x1="10" x2="10" y1="11" y2="17"/>
                    <line x1="14" x2="14" y1="11" y2="17"/>
                </svg>
                Eyða
            </button>
        </div>
    </AuthorizeView>
</div>
<div class="athlete-meta">
    <span>Fæðingarár: @Athlete?.YearOfBirth</span>
    @if (ShowClubs)
    {
        <span class="meta-separator">&middot;</span>
        <NavLink class="nav-link" href="@($"/teams/{Athlete?.ClubSlug}")">
            @Athlete?.Club
        </NavLink>
    }
</div>

@if (PersonalBests.Count > 0)
{
    @foreach (var group in PersonalBests.GroupBy(x => x.IsClassic))
    {
        <h3>Besti árangur @(DisplayNames.EquipmentType(group.Key).ToLowerInvariant())</h3>

        <div class="card-grid">
            @foreach (var best in group)
            {
                <Card>
                    <a href="@($"/meets/{best.MeetSlug}")" aria-label="@(best.Discipline switch { Discipline.Squat => Constants.Squat, Discipline.Bench => Constants.Bench, Discipline.Deadlift => Constants.Deadlift, _ => Constants.Total }) — @($"{best.Weight:F1}") kg@(best.IsSingleLift ? $" - {Constants.SingeLift}" : "")"></a>
                    @if (best.IsSingleLift)
                    {
                        <div class="card-badge">@Constants.SingeLift</div>
                    }
                    <div class="card-label">@(best.Discipline switch { Discipline.Squat => Constants.Squat, Discipline.Bench => Constants.Bench, Discipline.Deadlift => Constants.Deadlift, _ => Constants.Total })</div>
                    <div class="card-weight">@($"{best.Weight:F1}") <span class="card-unit">kg</span></div>
                    <div class="card-meta">
                        @($"{best.Date:dd-MM-yyyy}") &middot; @best.BodyWeight kg
                    </div>
                </Card>
            }
        </div>
        <br />
    }
}

@if (Records.Count > 0)
{
    <h3>Núverandi íslandsmet (@Records.Count)</h3>
    @foreach (var group in Records.GroupBy(x => x.IsClassic))
    {
        <h4>@DisplayNames.EquipmentType(group.Key) (@group.Count())</h4>
        <div class="card-grid">
            @foreach(var record in group)
            {
                <Card>
                    <a href="@($"/meets/{record.MeetSlug}")" aria-label="@record.Type — @($"{record.Weight:F1}") kg@(record.IsSingleLift ? $" - {Constants.SingeLift}" : "")"></a>
                    @if (record.IsSingleLift)
                    {
                        <div class="card-badge">@Constants.SingeLift</div>
                    }
                    <div class="card-label">@record.Type</div>
                    <div class="card-weight">@($"{record.Weight:F1}") <span class="card-unit">kg</span></div>
                    <div class="card-meta">
                        @($"{record.Date:dd-MM-yyyy}") &middot; @record.AgeCategory @record.WeightCategory
                    </div>
                </Card>
            }
        </div>
        <br />
    }

    <br />
}

@if (Participations.Count > 0)
{
    <h3>Ferill (@Participations.Count mót)</h3>

    <br />

    @foreach (var meetType in Participations.GroupBy(x => x.MeetType) ?? [])
    {
        <h4>@meetType.Key</h4>

        <div class="table-overflow">
            <table>

                <thead>
                    <tr>
                        <th>Dags.</th>

                        <th>Mót</th>

                        <th style="text-align: center; width: 42px;">#</th>

                        @if (ShowClubs)
                        {
                            <th style="text-align: center; width: 80px;">Félag</th>
                        }

                        <th style="text-align: center; width: 80px;">Þyngdarflokkur</th>

                        <th style="text-align: center; width: 80px;">Líkamsþyngd</th>

                        @if (meetType.Key == Constants.Powerlifting)
                        {
                            <th style="text-align: center; width: 80px;">
                                @Constants.Squat
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Bench))
                        {
                            <th style="text-align: center; width: 80px;">
                                @Constants.Bench
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Deadlift))
                        {
                            <th style="text-align: center; width: 80px;">
                                @(meetType.Any(x => x.Deadlift > 0) ? Constants.Deadlift : string.Empty)
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting)
                        {
                            <th style="text-align: center; width: 80px;">Samanlagt</th>
                        }

                        <th style="text-align: center; width: 80px;">IPF stig</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (AthleteParticipation p in meetType)
                    {
                        <tr>
                            <td>@p.Date.ToString("dd.MM.yyyy")</td>

                            <td>
                                <NavLink class="nav-link" href="@($"/meets/{p.MeetSlug}")">
                                    @p.Meet
                                </NavLink>
                            </td>

                            <RankCell Rank="@p.Rank" />
                            <ClubCell Club="@p.Club" Slug="@p.ClubSlug" IsVisible="@ShowClubs"/>

                            <td style="text-align: center;">@p.WeightCategory</td>

                            <td>
                                <BodyWeight Value="p.BodyWeight"/>
                            </td>

                            @if (meetType.Key == Constants.Powerlifting)
                            {
                                <WeightCell Weight="@p.Squat" />
                            }

                            @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Bench))
                            {
                                <WeightCell Weight="@p.Benchpress" />
                            }

                            @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Deadlift))
                            {
                                <WeightCell Weight="@p.Deadlift" />
                            }

                            @if (meetType.Key == Constants.Powerlifting)
                            {
                                <WeightCell Weight="@p.Total" />
                            }

                            <WeightCell Weight="@p.IpfPoints" SignificantDigits="2" />
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    }
}

<ConfirmDialog @ref="_deleteDialog"
               Id="delete-athlete-dialog"
               Title="Eyða keppanda"
               Message="Ertu viss um að þú viljir eyða þessum keppanda?"
               ConfirmLabel="Eyða keppanda"
               OnConfirm="HandleDelete"
               ErrorMessage="@_deleteErrorMessage"
               IsLoading="_isDeleting" />

@code {
    private ConfirmDialog _deleteDialog = null!;
    private bool _isDeleting;
    private string? _deleteErrorMessage;

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private AthleteDetails? Athlete;
    private bool ShowClubs;
    private IReadOnlyList<AthletePersonalBest> PersonalBests = [];
    private IReadOnlyList<AthleteRecord> Records = [];
    private IReadOnlyList<AthleteParticipation> Participations = [];

    private async Task ShowDeleteDialog()
    {
        _deleteErrorMessage = null;
        await _deleteDialog.ShowAsync();
    }

    private async Task HandleDelete()
    {
        try
        {
            _isDeleting = true;
            _deleteErrorMessage = null;

            HttpResponseMessage response = await HttpClient.DeleteAsync($"/athletes/{Slug}");

            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                _deleteErrorMessage = "Ekki er hægt að eyða keppanda sem hefur mótaskráningu.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _deleteErrorMessage = "Keppandi fannst ekki.";
            }
            else if (!response.IsSuccessStatusCode)
            {
                _deleteErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
            }
            else
            {
                NavigationManager.NavigateTo("/athletes");
                return;
            }
        }
        catch (HttpRequestException)
        {
            _deleteErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Athlete = await HttpClient.GetFromJsonAsync<AthleteDetails>($"/athletes/{Slug}");
        PersonalBests = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthletePersonalBest>>($"/athletes/{Slug}/personalbests") ?? [];
        Records = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthleteRecord>>($"/athletes/{Slug}/records") ?? [];
        Participations = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthleteParticipation>>($"/athletes/{Slug}/participations") ?? [];
        ShowClubs = Participations.Any(x => !string.IsNullOrWhiteSpace(x.Club));
    }
}
