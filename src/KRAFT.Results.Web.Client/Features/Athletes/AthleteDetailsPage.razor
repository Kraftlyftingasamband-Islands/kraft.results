@page "/athletes/{slug}"

@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes
@using KRAFT.Results.Web.Client.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing

@inject HttpClient HttpClient;

<h1>@Athlete?.Name</h1>
Fæðingarár: @Athlete?.YearOfBirth<br />
@if (ShowClubs)
{
    <NavLink class="nav-link" href="@($"/teams/{Athlete?.ClubSlug}")">
        @Athlete?.Club
    </NavLink>
}

<br/>

@if (PersonalBests.Count > 0)
{
    @foreach (var group in PersonalBests.GroupBy(x => x.IsClassic))
    {
        <h3>Besti árangur @(group.Key ? "án búnaðar" : "með búnaði")</h3>

        <div class="card-grid">
            @foreach (var best in group)
            {
                <Card>
                    <a href="@($"/meets/{best.MeetSlug}")" aria-label="@best.Discipline"></a>
                    <h5>@best.Discipline @(best.IsSingleLift ? $"({Constants.SingeLift})" : string.Empty)</h5>
                    <p>
                        @($"{best.Date:dd-MM-yyyy}")<br />
                        Líkamsþyngd: @best.BodyWeight kg
                    </p>
                    <h3 style="color: mediumseagreen; text-align: right">@($"{best.Weight:F1} kg")</h3>
                </Card>
            }
        </div>
        <br />
    }
}

@if (Records.Count > 0)
{
    <h3>Núverandi íslandsmet (@Records.Count)</h3>
    @foreach (var group in Records.GroupBy(x => x.IsClassic))
    {
        <h4>@(group.Key ? "Án búnaðar" : "Með búnaði") (@group.Count())</h4>
        <div class="card-grid">
            @foreach(var record in group)
            {
                <Card>
                    <a href="@($"/meets/{record.MeetSlug}")" aria-label="@record.Type"></a>
                    <h5>@record.Type</h5>
                    <p>
                        @($"{record.Date:dd-MM-yyyy}")<br />
                        @record.AgeCategory @record.WeightCategory
                    </p>
                    <h3 style="color: mediumseagreen; text-align: right">@($"{record.Weight:F1} kg")</h3>
                </Card>
            }
        </div>
        <br />
    }

    <br />
}

@if (Participations.Count > 0)
{
    <h3>Ferill (@Participations.Count mót)</h3>

    <br />

    @foreach (var meetType in Participations.GroupBy(x => x.MeetType) ?? [])
    {
        <h4>@meetType.Key</h4>

        <div class="table-overflow">
            <table>

                <thead>
                    <tr>
                        <th>Dags.</th>

                        <th>Mót</th>

                        <th style="text-align: center; width: 42px;">#</th>

                        @if (ShowClubs)
                        {
                            <th style="text-align: center; width: 80px;">Félag</th>
                        }

                        <th style="text-align: center; width: 80px;">Þyngdarflokkur</th>

                        <th style="text-align: center; width: 80px;">Líkamsþyngd</th>

                        @if (meetType.Key == Constants.Powerlifting)
                        {
                            <th style="text-align: center; width: 80px;">
                                @Constants.Squat
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Bench))
                        {
                            <th style="text-align: center; width: 80px;">
                                @Constants.Bench
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Deadlift))
                        {
                            <th style="text-align: center; width: 80px;">
                                @(meetType.Any(x => x.Deadlift > 0) ? Constants.Deadlift : string.Empty)
                            </th>
                        }

                        @if (meetType.Key == Constants.Powerlifting)
                        {
                            <th style="text-align: center; width: 80px;">Samanlagt</th>
                        }

                        <th style="text-align: center; width: 80px;">IPF stig</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (AthleteParticipation p in meetType)
                    {
                        <tr>
                            <td>@p.Date.ToString("dd.MM.yyyy")</td>

                            <td>
                                <NavLink class="nav-link" href="@($"/meets/{p.MeetSlug}")">
                                    @p.Meet
                                </NavLink>
                            </td>

                            <RankCell Rank="@p.Rank" />
                            <ClubCell Club="@p.Club" Slug="@p.ClubSlug" IsVisible="@ShowClubs"/>

                            <td style="text-align: center;">@p.WeightCategory</td>

                            <td>
                                <BodyWeight Value="p.BodyWeight"/>
                            </td>

                            @if (meetType.Key == Constants.Powerlifting)
                            {
                                <WeightCell Weight="@p.Squat" />
                            }

                            @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Bench))
                            {
                                <WeightCell Weight="@p.Benchpress" />
                            }

                            @if (meetType.Key == Constants.Powerlifting || meetType.Key.StartsWith(Constants.Deadlift))
                            {
                                <WeightCell Weight="@p.Deadlift" />
                            }

                            @if (meetType.Key == Constants.Powerlifting)
                            {
                                <WeightCell Weight="@p.Total" />
                            }

                            <WeightCell Weight="@p.IpfPoints" SignificantDigits="2" />
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private AthleteDetails? Athlete;
    private bool ShowClubs;
    private IReadOnlyList<AthletePersonalBest> PersonalBests = [];
    private IReadOnlyList<AthleteRecord> Records = [];
    private IReadOnlyList<AthleteParticipation> Participations = [];

    protected override async Task OnInitializedAsync()
    {
        Athlete = await HttpClient.GetFromJsonAsync<AthleteDetails>($"/athletes/{Slug}");
        PersonalBests = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthletePersonalBest>>($"/athletes/{Slug}/personalbests") ?? [];
        Records = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthleteRecord>>($"/athletes/{Slug}/records") ?? [];
        Participations = await HttpClient.GetFromJsonAsync<IReadOnlyList<AthleteParticipation>>($"/athletes/{Slug}/participations") ?? [];
        ShowClubs = Participations.Any(x => !string.IsNullOrWhiteSpace(x.Club));
    }
}
