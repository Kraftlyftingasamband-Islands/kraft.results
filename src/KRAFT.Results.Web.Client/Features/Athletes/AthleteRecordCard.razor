@using System.Globalization
@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes

<div class="ar-card">
    <div class="ar-header-row">
        <div class="ar-cat">@Record.WeightCategory</div>
        <div class="ar-name-col">
            <span class="ar-type">
                @if (Record.IsSingleLift)
                {
                    <span class="ar-sl-badge">@Constants.SingeLift</span>
                }
                @Record.Type
            </span>
            <span class="ar-meta">@Record.AgeCategory · @Record.Date.ToString("dd.MM.yyyy")</span>
        </div>
        <div class="ar-mark-col">
            <a class="ar-mark ar-mark-link" href="@($"/meets/{Record.MeetSlug}")">@Record.Weight.ToString("F1", CultureInfo.InvariantCulture)</a>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public AthleteRecord Record { get; set; } = null!;
}