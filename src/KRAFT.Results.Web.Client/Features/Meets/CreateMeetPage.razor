@page "/meets/create"

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@attribute [Authorize(Roles = "Admin")]

@using System.Net
@using KRAFT.Results.Contracts.Meets

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<PageTitle>Nýtt mót</PageTitle>
<h3>Nýtt mót</h3>

<MeetForm MeetTypes="_meetTypes"
          OnSubmit="HandleSubmit"
          IsLoading="_isLoading"
          ErrorMessage="@_errorMessage"
          SubmitLabel="Stofna mót"
          BackUrl="/meets" />

@code {
    private IReadOnlyList<MeetTypeSummary> _meetTypes = [];
    private bool _isLoading;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _meetTypes = await HttpClient.GetFromJsonAsync<IReadOnlyList<MeetTypeSummary>>("/meets/types") ?? [];
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Gat ekki sótt mótategundir. Reyndu að endurhlaða síðuna.";
        }
    }

    private async Task HandleSubmit(MeetFormValues values)
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            CreateMeetCommand command = new(
                values.Title,
                values.StartDate,
                values.MeetTypeId,
                values.EndDate,
                values.CalcPlaces,
                values.Text,
                values.Location,
                values.PublishedResults,
                values.ResultModeId,
                values.PublishedInCalendar,
                values.IsInTeamCompetition,
                values.ShowWilks,
                values.ShowTeamPoints,
                values.ShowBodyWeight,
                values.ShowTeams,
                values.RecordsPossible,
                values.IsRaw);
            HttpResponseMessage response = await HttpClient.PostAsJsonAsync("/meets", command);

            if (response.StatusCode == HttpStatusCode.Conflict)
            {
                _errorMessage = "Mót með þessu nafni og dagsetningu er þegar til.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Villa kom upp. Reyndu aftur síðar.";
                return;
            }

            NavigationManager.NavigateTo("/meets");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
