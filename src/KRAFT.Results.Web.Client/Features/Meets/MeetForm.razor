@using System.ComponentModel.DataAnnotations
@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Meets

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleValidSubmit" FormName="meet-form">
        <DataAnnotationsValidator />

        <div class="form-field">
            <label class="form-label" for="title">Nafn</label>
            <InputText id="title"
                       class="form-input"
                       aria-required="true"
                       aria-describedby="@GetAriaDescribedBy("title-error")"
                       @bind-Value="_model.Title"
                       disabled="@IsLoading" />
            <div id="title-error">
                <ValidationMessage For="@(() => _model.Title)" />
            </div>
        </div>

        <div class="form-field">
            <label class="form-label" for="start-date">Dagsetning</label>
            <InputDate id="start-date"
                       class="form-input"
                       aria-required="true"
                       aria-describedby="@GetAriaDescribedBy("start-date-error")"
                       @bind-Value="_model.StartDate"
                       disabled="@IsLoading" />
            <div id="start-date-error">
                <ValidationMessage For="@(() => _model.StartDate)" />
            </div>
        </div>

        <div class="form-field">
            <label class="form-label" for="meet-type">Tegund móts</label>
            <InputSelect id="meet-type"
                         class="form-input form-select"
                         aria-required="true"
                         aria-describedby="@GetAriaDescribedBy("meet-type-error")"
                         @bind-Value="_model.MeetTypeId"
                         disabled="@IsLoading">
                <option value="0">-- Veldu tegund --</option>
                @foreach (MeetTypeSummary meetType in MeetTypes)
                {
                    <option value="@meetType.Id">@TranslateMeetType(meetType.Title)</option>
                }
            </InputSelect>
            <div id="meet-type-error">
                <ValidationMessage For="@(() => _model.MeetTypeId)" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary" disabled="@IsLoading" aria-busy="@IsLoading">
                @if (IsLoading)
                {
                    <span>Augnablik...</span>
                }
                else
                {
                    <span>@SubmitLabel</span>
                }
            </button>

            <a href="@BackUrl" class="btn-cancel">Til baka</a>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <ErrorMessage Id="meet-form-error" Message="@ErrorMessage" />
        }
    </EditForm>
</div>

@code {
    private readonly MeetFormModel _model = new();
    private bool _initialized;

    [Parameter, EditorRequired]
    public IReadOnlyList<MeetTypeSummary> MeetTypes { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<MeetFormValues> OnSubmit { get; set; }

    [Parameter, EditorRequired]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter, EditorRequired]
    public string SubmitLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string BackUrl { get; set; } = string.Empty;

    [Parameter]
    public MeetFormInitialValues? InitialValues { get; set; }

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private string GetAriaDescribedBy(string fieldErrorId)
    {
        return HasError ? $"{fieldErrorId} meet-form-error" : fieldErrorId;
    }

    protected override void OnParametersSet()
    {
        if (!_initialized && InitialValues is not null)
        {
            _model.Title = InitialValues.Title;
            _model.StartDate = InitialValues.StartDate;
            _model.MeetTypeId = InitialValues.MeetTypeId;
            _initialized = true;
            return;
        }

        if (!_initialized && _model.MeetTypeId == 0 && MeetTypes.Count > 0)
        {
            MeetTypeSummary? powerlifting = MeetTypes.FirstOrDefault(x => x.Title == "Powerlifting");

            if (powerlifting is not null)
            {
                _model.MeetTypeId = powerlifting.Id;
            }

            _initialized = true;
        }
    }

    private static string TranslateMeetType(string title) => title switch
    {
        "Powerlifting" => Constants.Powerlifting,
        "Benchpress" => Constants.Bench,
        "Deadlift" => Constants.Deadlift,
        "Squat" => Constants.Squat,
        "PushPull" => "Pressa og toga",
        _ => title,
    };

    private async Task HandleValidSubmit()
    {
        MeetFormValues values = new(
            _model.Title,
            _model.StartDate!.Value,
            _model.MeetTypeId);

        await OnSubmit.InvokeAsync(values);
    }

    private sealed class MeetFormModel
    {
        [Required(ErrorMessage = "Nafn er skylda")]
        [MaxLength(100, ErrorMessage = "Nafn má ekki vera lengra en 100 stafir")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "Dagsetning er skylda")]
        public DateOnly? StartDate { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Vinsamlegast veldu tegund móts")]
        public int MeetTypeId { get; set; }
    }
}
