@using System.ComponentModel.DataAnnotations
@using KRAFT.Results.Contracts.Meets

<div class="form-card">
    <EditForm Model="_model" OnValidSubmit="HandleValidSubmit" FormName="meet-form">
        <DataAnnotationsValidator />

        <div class="form-field">
            <label class="form-label" for="title">Nafn</label>
            <InputText id="title"
                       class="form-input"
                       aria-required="true"
                       aria-describedby="@(HasError ? "meet-form-error" : null)"
                       @bind-Value="_model.Title"
                       disabled="@IsLoading" />
            <ValidationMessage For="@(() => _model.Title)" />
        </div>

        <div class="form-field">
            <label class="form-label" for="start-date">Dagsetning</label>
            <InputDate id="start-date"
                       class="form-input"
                       aria-required="true"
                       aria-describedby="@(HasError ? "meet-form-error" : null)"
                       @bind-Value="_model.StartDate"
                       disabled="@IsLoading" />
            <ValidationMessage For="@(() => _model.StartDate)" />
        </div>

        <div class="form-field">
            <label class="form-label" for="meet-type">Tegund móts</label>
            <InputSelect id="meet-type"
                         class="form-input form-select"
                         aria-required="true"
                         aria-describedby="@(HasError ? "meet-form-error" : null)"
                         @bind-Value="_model.MeetTypeId"
                         disabled="@IsLoading">
                <option value="0">-- Veldu tegund --</option>
                @foreach (MeetTypeSummary meetType in MeetTypes)
                {
                    <option value="@meetType.Id">@meetType.Title</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => _model.MeetTypeId)" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary" disabled="@IsLoading" aria-busy="@IsLoading">
                @if (IsLoading)
                {
                    <span>Augnablik...</span>
                }
                else
                {
                    <span>@SubmitLabel</span>
                }
            </button>

            <a href="@BackUrl" class="btn-cancel">Til baka</a>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div id="meet-form-error" class="error-message" role="alert">@ErrorMessage</div>
        }
    </EditForm>
</div>

@code {
    private readonly MeetFormModel _model = new();

    [Parameter, EditorRequired]
    public IReadOnlyList<MeetTypeSummary> MeetTypes { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<CreateMeetCommand> OnSubmit { get; set; }

    [Parameter, EditorRequired]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter, EditorRequired]
    public string SubmitLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string BackUrl { get; set; } = string.Empty;

    private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

    private async Task HandleValidSubmit()
    {
        CreateMeetCommand command = new(
            _model.Title,
            _model.StartDate!.Value,
            _model.MeetTypeId);

        await OnSubmit.InvokeAsync(command);
    }

    private sealed class MeetFormModel
    {
        [Required]
        public string Title { get; set; } = string.Empty;

        [Required]
        public DateOnly? StartDate { get; set; }

        [Range(1, int.MaxValue)]
        public int MeetTypeId { get; set; }
    }
}
