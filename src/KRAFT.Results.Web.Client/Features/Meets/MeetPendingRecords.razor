@using KRAFT.Results.Contracts.Records

@inject HttpClient HttpClient

<section class="card-section pending-records-section">
    <div class="pending-records-header">
        <h3>Met til samþykktar</h3>
        @if (PendingRecords.Count > 0)
        {
            <span class="badge">@PendingRecords.Count í bið</span>
        }
    </div>

    @if (_errorMessage is not null)
    {
        <div class="pending-records-error" role="alert">@_errorMessage</div>
    }

    @if (PendingRecords.Count == 0)
    {
        <p class="empty-state">Engin met í bið.</p>
    }
    else
    {
        <div class="table-overflow">
            <table aria-label="Met til samþykktar">
                <thead>
                    <tr>
                        <th scope="col" style="text-align: center; width: 42px;">#</th>
                        <th scope="col">Keppandi</th>
                        <th scope="col">Grein</th>
                        <th scope="col" style="text-align: right; width: 80px;">Mark</th>
                        <th scope="col" class="hide-mobile" style="text-align: center; width: 100px;">Þyngdarfl.</th>
                        <th scope="col" class="hide-mobile" style="text-align: center; width: 100px;">Aldursfl.</th>
                        <th scope="col" style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach ((PendingRecordEntry record, int index) in PendingRecords.Select((r, i) => (r, i)))
                    {
                        <tr class="@(_fadingAttemptIds.Contains(record.AttemptId) ? "row-fading" : null)">
                            <td style="text-align: center;">@(index + 1)</td>
                            <td>@record.AthleteName</td>
                            <td>@record.Discipline</td>
                            <td style="text-align: right;">@record.Weight</td>
                            <td class="hide-mobile" style="text-align: center;">@record.WeightCategory</td>
                            <td class="hide-mobile" style="text-align: center;">@record.AgeCategory</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-approve"
                                            disabled="@(_processingAttemptId is not null)"
                                            aria-label="@($"Samþykkja met – {record.AthleteName}, {record.Discipline}")"
                                            @onclick="() => HandleApprove(record.AttemptId)">
                                        @if (_processingAttemptId == record.AttemptId)
                                        {
                                            <span class="spinner"></span>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="action-icon">
                                                <polyline points="20 6 9 17 4 12"/>
                                            </svg>
                                        }
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private int? _processingAttemptId;
    private string? _errorMessage;
    private readonly HashSet<int> _fadingAttemptIds = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<PendingRecordEntry> PendingRecords { get; set; } = [];

    [Parameter]
    public string MeetSlug { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<int> OnRecordApproved { get; set; }

    private async Task HandleApprove(int attemptId)
    {
        _processingAttemptId = attemptId;
        _errorMessage = null;

        try
        {
            HttpResponseMessage response = await HttpClient.PutAsync($"/meets/{MeetSlug}/pending-records/{attemptId}/approve", null);

            if (response.IsSuccessStatusCode)
            {
                _fadingAttemptIds.Add(attemptId);
                StateHasChanged();
                await Task.Delay(300);
                await OnRecordApproved.InvokeAsync(attemptId);
            }
            else
            {
                _errorMessage = "Villa kom upp við að samþykkja met. Reyndu aftur síðar.";
                _ = ScheduleErrorDismissAsync();
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Villa kom upp við að samþykkja met. Reyndu aftur síðar.";
            _ = ScheduleErrorDismissAsync();
        }
        finally
        {
            _processingAttemptId = null;
        }
    }

    private async Task ScheduleErrorDismissAsync()
    {
        await Task.Delay(5000);
        _errorMessage = null;
        StateHasChanged();
    }
}
