@page "/meets/{slug}"
@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Meets
@using KRAFT.Results.Contracts.Records
@using KRAFT.Results.Contracts.TeamCompetition
@using KRAFT.Results.Web.Client.Components
@using KRAFT.Results.Web.Client.Features.TeamCompetition
@using Microsoft.AspNetCore.Components.Authorization

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

@if (_errorMessage is not null)
{
    <div role="alert" class="error-message">
        <p>@_errorMessage</p>
        <a href="/meets">Til baka í mótslista</a>
    </div>
}

<div class="page-header">
    <h1>@Meet?.Title</h1>
    <AuthorizeView Roles="Admin">
        <div class="admin-actions">
            <a href="/meets/@Slug/edit" class="btn-action" aria-label="Breyta móti">
                <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                    <path d="m15 5 4 4"/>
                </svg>
                Breyta
            </a>
            <button class="btn-action btn-danger" aria-label="Eyða móti" @onclick="ShowDeleteDialog">
                <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18"/>
                    <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                    <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                    <line x1="10" x2="10" y1="11" y2="17"/>
                    <line x1="14" x2="14" y1="11" y2="17"/>
                </svg>
                Eyða
            </button>
        </div>
    </AuthorizeView>
</div>
<p>
    @($"{Meet?.StartDate:dd-MM-yyyy}")
    @if (Meet?.EndDate is DateOnly endDate && endDate != Meet?.StartDate)
    {
        <span> - @($"{endDate:dd-MM-yyyy}")</span>
    }
    <br />
    @Meet?.Location<br />
</p>

<AuthorizeView Roles="Admin">
    <MeetPendingRecords PendingRecords="_pendingRecords"
                        OnRecordApproved="HandleRecordApproved"
                        OnRecordRejected="HandleRecordRejected" />
</AuthorizeView>

@if (ShowIpfPointLeaders)
{
    <h2>Stigahæstu keppendur</h2>
    <div class="card-grid card-grid-2">
        @foreach (var gender in Participations.GroupBy(x => x.Gender).OrderByDescending(x => x.Key))
        {
            <section class="card-section">
                <h4>@gender.Key</h4>
                <div class="table-overflow">
                    <table>
                        <thead>
                            <tr>
                                <th style="text-align: center; width: 42px;">#</th>
                                <th>Nafn</th>
                                <th style="text-align: center; width: 80px;">Fæðingarár</th>

                                @if (ShowClubs)
                                {
                                    <th style="text-align: center; width: 80px;">Félag</th>
                                }

                                <th style="text-align: center; width: 80px;">Líkamsþyngd</th>
                                <th style="text-align: right; width: 80px;">IPF stig</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in gender.OrderByDescending(p => p.IpfPoints).Select((participation, index) => (Rank: index + 1, Participation: participation)).Take(3))
                            {
                                <tr>
                                    <RankCell Rank="p.Rank" />
                                    <AthleteCell Athlete="@p.Participation.Athlete" Slug="@p.Participation.AthleteSlug" />
                                    <td>
                                        <BirthYear Year="@p.Participation.YearOfBirth" RelativeYear="@(Meet?.StartDate.Year ?? 0)" />
                                    </td>
                                    <ClubCell Club="@p.Participation.Club" Slug="@p.Participation.ClubSlug" IsVisible="@ShowClubs" />
                                    <td>
                                        <BodyWeight Value="p.Participation.BodyWeight" />
                                    </td>
                                    <WeightCell Weight="p.Participation.IpfPoints" SignificantDigits="2" />
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
    <br/>
}

<h2>Úrslit</h2>

@foreach (var genderAgeAgeCategory in Participations
    .Where(x => !string.IsNullOrEmpty(x.AgeCategory))
    .GroupBy(x => new { x.Gender, x.AgeCategory, x.AgeCategorySlug })
    .OrderBy(x => Array.IndexOf(Constants.AgeCategoryOrder, x.Key.AgeCategorySlug.Length > 0 ? char.ToUpperInvariant(x.Key.AgeCategorySlug[0]) : ' '))
    .ThenBy(x => x.Key.AgeCategorySlug)
    .ThenByDescending(x => x.Key.Gender))
{
    <section class="card-section">
        <h4>@genderAgeAgeCategory.Key.Gender - @genderAgeAgeCategory.Key.AgeCategory</h4>
        <br />

        @foreach (var weightCategory in genderAgeAgeCategory
            .GroupBy(x => x.WeightCategory)
            .OrderBy(x => x.Max(y => y.BodyWeight)))
        {
            <h5>@weightCategory.Key kg</h5>
            <div class="table-overflow">
                <table>
                    <tbody>
                        <tr>
                            <th style="text-align: center; width: 42px;">#</th>
                            <th>Nafn</th>
                            <th style="text-align: center; width: 80px;">Fæðingarár</th>

                            @if (ShowClubs)
                            {
                                <th style="text-align: center; width: 80px;">Félag</th>
                            }

                            <th style="text-align: center; width: 80px;">Líkamsþyngd</th>

                            @foreach (var disciplineGroup in weightCategory.First().Attempts
                                .Where(a => IncludedDisciplines.GetValueOrDefault(a.Discipline))
                                .GroupBy(a => a.Discipline)
                                .OrderBy(g => (byte)g.Key))
                            {
                                int roundCount = disciplineGroup.Count();
                                string disciplineLabel = disciplineGroup.Key.ToDisplayName();
                                <th colspan="@roundCount" class="first-attempt" style="text-align: center; width: @(80 * roundCount)px">@disciplineLabel</th>
                            }

                            <th class="first-attempt" style="text-align: right; width: 80px;">@Constants.Total</th>

                            @if (ShowIpfPoints)
                            {
                                <th style="text-align: right; width: 80px;">IPF stig</th>
                            }
                        </tr>

                        @foreach (var p in weightCategory
                            .OrderBy(x => x.Disqualified)
                            .ThenBy(x => x.Rank <= 0)
                            .ThenBy(x => x.Rank)
                            .ThenBy(x => x.Athlete))
                        {
                            <tr class="@(p.Disqualified ? "bombed-out" : null)">
                                <RankCell Rank="p.Rank"/>
                                <AthleteCell Athlete="@p.Athlete" Slug="@p.AthleteSlug" />
                                <td>
                                    <BirthYear Year="@p.YearOfBirth" RelativeYear="@(Meet?.StartDate.Year ?? 0)" />
                                </td>
                                <ClubCell Club="@p.Club" Slug="@p.ClubSlug" IsVisible="@ShowClubs" />
                                <td>
                                    <BodyWeight Value="p.BodyWeight" />
                                </td>

                                @foreach (var discipline in p.Attempts.GroupBy(a => a.Discipline))
                                {
                                    @foreach (var attempt in discipline.Where(a => IncludedDisciplines.GetValueOrDefault(a.Discipline)).OrderBy(a => a.Round))
                                    {
                                        <AttemptCell Attempt="attempt" />
                                    }
                                }

                                <WeightCell Weight="p.Total" />

                                @if (ShowIpfPoints)
                                {
                                    <WeightCell Weight="p.IpfPoints" SignificantDigits="2" />
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
    <br />
}

@if (ShowTeamStandings)
{
    <h2>Liðakeppni</h2>

    @if (IsPreGenderSplit)
    {
        <div class="standings-grid standings-grid-single">
            <div class="gender-section">
                <StandingsTable Standings="_teamPointsResponse!.Combined"
                                AriaLabel="Stigatafla liða í móti" />
            </div>
        </div>
    }
    else
    {
        <div class="standings-grid">
            <div class="gender-section">
                <h3 class="section-header">@("f".ToGenderGroupLabel())</h3>
                @if (_teamPointsResponse!.Women.Count > 0)
                {
                    <StandingsTable Standings="_teamPointsResponse!.Women"
                                    AriaLabel="Stigatafla kvenna í móti" />
                }
                else
                {
                    <div class="empty-section">Engar niðurstöður.</div>
                }
            </div>
            <div class="gender-section">
                <h3 class="section-header">@("m".ToGenderGroupLabel())</h3>
                @if (_teamPointsResponse!.Men.Count > 0)
                {
                    <StandingsTable Standings="_teamPointsResponse!.Men"
                                    AriaLabel="Stigatafla karla í móti" />
                }
                else
                {
                    <div class="empty-section">Engar niðurstöður.</div>
                }
            </div>
        </div>
    }
}

<ConfirmDialog @ref="_deleteDialog"
               Id="delete-meet-dialog"
               Title="Eyða móti"
               Message="@($"Ertu viss um að þú viljir eyða mótinu \"{Meet?.Title}\"?")"
               ConfirmLabel="Eyða móti"
               OnConfirm="HandleDelete"
               ErrorMessage="@_deleteErrorMessage"
               IsLoading="_isDeleting" />

@code {
    private ConfirmDialog _deleteDialog = null!;
    private bool _isDeleting;
    private string? _deleteErrorMessage;
    private List<PendingRecordEntry> _pendingRecords = [];

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private MeetDetails? Meet;
    private IReadOnlyList<MeetParticipation> Participations = [];
    private Dictionary<Discipline, bool> IncludedDisciplines = new();
    private MeetTeamPointsResponse? _teamPointsResponse;
    private bool ShowIpfPoints;
    private bool ShowIpfPointLeaders;
    private bool ShowClubs;
    private bool ShowTeamStandings;
    private bool IsPreGenderSplit;
    private string? _errorMessage;

    private async Task ShowDeleteDialog()
    {
        _deleteErrorMessage = null;
        await _deleteDialog.ShowAsync();
    }

    private void HandleRecordApproved(int recordId)
    {
        _pendingRecords = _pendingRecords.Where(r => r.RecordId != recordId).ToList();
    }

    private void HandleRecordRejected(int recordId)
    {
        _pendingRecords = _pendingRecords.Where(r => r.RecordId != recordId).ToList();
    }

    private async Task HandleDelete()
    {
        try
        {
            _isDeleting = true;
            _deleteErrorMessage = null;

            HttpResponseMessage response = await HttpClient.DeleteAsync($"/meets/{Slug}");

            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                _deleteErrorMessage = "Ekki er hægt að eyða móti sem hefur keppendur skráða.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _deleteErrorMessage = "Mót fannst ekki.";
            }
            else if (!response.IsSuccessStatusCode)
            {
                _deleteErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
            }
            else
            {
                NavigationManager.NavigateTo("/meets");
                return;
            }
        }
        catch (HttpRequestException)
        {
            _deleteErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Meet = await HttpClient.GetFromJsonAsync<MeetDetails>($"/meets/{Slug}");
            Participations = await HttpClient.GetFromJsonAsync<IReadOnlyList<MeetParticipation>>($"/meets/{Slug}/participations") ?? [];

            if (Meet is null)
            {
                _errorMessage = "Mót fannst ekki.";
                return;
            }

            IncludedDisciplines = Participations
                .SelectMany(participation => participation.Attempts)
                .GroupBy(attempt => attempt.Discipline)
                .ToDictionary(group => group.Key, group => group.Any(attempt => attempt.Weight > 0));

            ShowIpfPoints = Participations.Any(x => x.IpfPoints > 0);
            ShowIpfPointLeaders = Meet?.CalculatePlaces is true && ShowIpfPoints;
            ShowClubs = Participations.Any(x => !string.IsNullOrWhiteSpace(x.Club));

            if (Meet?.ShowTeamPoints is true)
            {
                _teamPointsResponse = await HttpClient.GetFromJsonAsync<MeetTeamPointsResponse>($"/meets/{Slug}/team-points");
                ShowTeamStandings = _teamPointsResponse is not null
                    && (_teamPointsResponse.Women.Count > 0
                        || _teamPointsResponse.Men.Count > 0
                        || _teamPointsResponse.Combined.Count > 0);
                IsPreGenderSplit = Meet.StartDate.Year < 2015;
            }

            try
            {
                _pendingRecords = await HttpClient.GetFromJsonAsync<List<PendingRecordEntry>>($"/meets/{Slug}/pending-records") ?? [];
            }
            catch (HttpRequestException)
            {
                _pendingRecords = [];
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Villa kom upp við að sækja mót. Reyndu aftur síðar.";
        }
    }

}
