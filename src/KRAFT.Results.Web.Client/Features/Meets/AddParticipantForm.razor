@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Athletes
@using KRAFT.Results.Contracts.Meets
@using KRAFT.Results.Contracts.Teams
@using System.Globalization

@inject HttpClient HttpClient

<div class="add-participant-form">
    <form @onsubmit="HandleSubmit">
        <div class="form-row">
            <div class="field field-athlete">
                <label class="form-label" for="athlete-input">Keppandi</label>
                <div class="athlete-typeahead">
                    <input id="athlete-input"
                           class="form-input"
                           type="text"
                           autocomplete="off"
                           placeholder="Leita..."
                           role="combobox"
                           aria-autocomplete="list"
                           aria-controls="athlete-listbox"
                           aria-expanded="@_showDropdown.ToString().ToLowerInvariant()"
                           aria-activedescendant="@(_showDropdown && _filteredAthletes.Count > 0 ? $"athlete-option-{_highlightedAthleteIndex}" : "")"
                           value="@_searchText"
                           @oninput="HandleSearchInput"
                           @onfocus="() => _showDropdown = true"
                           @onblur="HandleBlur"
                           @onkeydown="HandleAthleteKeyDown"
                           @onkeydown:preventDefault="@_preventDefaultOnAthleteInput" />
                    @if (_showDropdown && _filteredAthletes.Count > 0)
                    {
                        <ul id="athlete-listbox" class="typeahead-dropdown" role="listbox">
                            @for (int i = 0; i < _filteredAthletes.Count; i++)
                            {
                                int index = i;
                                <li id="athlete-option-@index"
                                    role="option"
                                    aria-selected="@((index == _highlightedAthleteIndex).ToString().ToLowerInvariant())"
                                    class="@(index == _highlightedAthleteIndex ? "highlighted" : "")"
                                    @onmousedown="() => SelectAthlete(_filteredAthletes[index])">
                                    @_filteredAthletes[index].Name
                                    @if (_filteredAthletes[index].YearOfBirth is not null)
                                    {
                                        <span class="typeahead-year">@_filteredAthletes[index].YearOfBirth</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="field field-bodyweight">
                <label class="form-label" for="bodyweight-input">Þyngd (kg)</label>
                <input id="bodyweight-input"
                       class="form-input"
                       type="text"
                       inputmode="decimal"
                       autocomplete="off"
                       @bind="_bodyWeight"
                       @bind:culture="CultureInfo.InvariantCulture"
                       @bind:event="oninput" />
            </div>

            <div class="field field-team">
                <label class="form-label" for="team-input">Lið</label>
                <div class="team-typeahead">
                    <input id="team-input"
                           class="form-input"
                           type="text"
                           autocomplete="off"
                           placeholder="Leita..."
                           role="combobox"
                           aria-autocomplete="list"
                           aria-controls="team-listbox"
                           aria-expanded="@_showTeamDropdown.ToString().ToLowerInvariant()"
                           aria-activedescendant="@(_showTeamDropdown && _filteredTeams.Count > 0 ? $"team-option-{_highlightedTeamIndex}" : "")"
                           value="@_teamSearchText"
                           @oninput="HandleTeamSearchInput"
                           @onfocus="() => _showTeamDropdown = true"
                           @onblur="HandleTeamBlur"
                           @onkeydown="HandleTeamKeyDown"
                           @onkeydown:preventDefault="@_preventDefaultOnTeamInput" />
                    @if (_showTeamDropdown && _filteredTeams.Count > 0)
                    {
                        <ul id="team-listbox" class="typeahead-dropdown" role="listbox">
                            @for (int i = 0; i < _filteredTeams.Count; i++)
                            {
                                int index = i;
                                <li id="team-option-@index"
                                    role="option"
                                    aria-selected="@((index == _highlightedTeamIndex).ToString().ToLowerInvariant())"
                                    class="@(index == _highlightedTeamIndex ? "highlighted" : "")"
                                    @onmousedown="() => SelectTeam(_filteredTeams[index])">
                                    @_filteredTeams[index].Title
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            @foreach (Discipline disc in IncludedDisciplines
                .Where(kv => kv.Value)
                .Select(kv => kv.Key)
                .OrderBy(d => (byte)d))
            {
                <div class="field field-discipline">
                    <span class="form-label">@disc.ToDisplayName()</span>
                    <div class="attempt-inputs">
                        @for (short round = 1; round <= 3; round++)
                        {
                            short r = round;
                            Discipline d = disc;
                            <div class="attempt-slot">
                                <label class="attempt-round-label" for="@($"attempt-{(int)d}-{r}")">@r</label>
                                <input id="@($"attempt-{(int)d}-{r}")"
                                       class="form-input attempt-input"
                                       type="text"
                                       inputmode="decimal"
                                       autocomplete="off"
                                       value="@GetAttemptValue(d, r)"
                                       @onchange="(e) => SetAttemptValue(d, r, e.Value?.ToString())" />
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="field field-submit">
                <button type="submit"
                        class="btn-action @(IsFormValid ? "btn-ready" : "")"
                        disabled="@(!IsFormValid)"
                        title="@(IsFormValid ? "" : SubmitHint)">
                    Bæta við
                </button>
            </div>
        </div>

        @if (_errorMessage is not null)
        {
            <div class="form-error" role="alert">@_errorMessage</div>
        }
    </form>
</div>

@code {
    private List<AthleteSummary> _athletes = [];
    private List<AthleteSummary> _filteredAthletes = [];
    private string _searchText = string.Empty;
    private string _selectedAthleteSlug = string.Empty;
    private decimal _bodyWeight;
    private bool _showDropdown;
    private int _highlightedAthleteIndex;
    private bool _preventDefaultOnAthleteInput;
    private string? _errorMessage;
    private Dictionary<(Discipline, short), string> _attemptValues = [];

    private List<TeamOption> _teams = [];
    private List<TeamOption> _filteredTeams = [];
    private string _teamSearchText = string.Empty;
    private int? _selectedTeamId;
    private bool _showTeamDropdown;
    private int _highlightedTeamIndex;
    private bool _preventDefaultOnTeamInput;

    [Parameter, EditorRequired]
    public int MeetId { get; set; }

    [Parameter, EditorRequired]
    public Dictionary<Discipline, bool> IncludedDisciplines { get; set; } = new();

    [Parameter]
    public IReadOnlyCollection<string> RegisteredAthletes { get; set; } = [];

    [Parameter]
    public EventCallback OnParticipantAdded { get; set; }

    private bool IsFormValid =>
        !string.IsNullOrEmpty(_selectedAthleteSlug) && _bodyWeight > 0;

    private string SubmitHint
    {
        get
        {
            List<string> missing = [];

            if (string.IsNullOrEmpty(_selectedAthleteSlug))
            {
                missing.Add("veldu keppanda");
            }

            if (_bodyWeight <= 0)
            {
                missing.Add("sláðu inn þyngd");
            }

            if (missing.Count == 0)
            {
                return string.Empty;
            }

            string hint = string.Join(", ", missing);
            return char.ToUpper(hint[0]) + hint[1..];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _athletes = await HttpClient.GetFromJsonAsync<List<AthleteSummary>>("/athletes") ?? [];
        }
        catch (HttpRequestException)
        {
            _athletes = [];
        }

        try
        {
            _teams = await HttpClient.GetFromJsonAsync<List<TeamOption>>("/teams/options") ?? [];
        }
        catch (HttpRequestException)
        {
            _teams = [];
        }

        InitializeAttemptValues();
    }

    private void InitializeAttemptValues()
    {
        _attemptValues = [];

        foreach (Discipline disc in IncludedDisciplines.Where(kv => kv.Value).Select(kv => kv.Key))
        {
            for (short round = 1; round <= 3; round++)
            {
                _attemptValues[(disc, round)] = string.Empty;
            }
        }
    }

    private string GetAttemptValue(Discipline discipline, short round)
    {
        return _attemptValues.GetValueOrDefault((discipline, round), string.Empty);
    }

    private void SetAttemptValue(Discipline discipline, short round, string? value)
    {
        _attemptValues[(discipline, round)] = value ?? string.Empty;
    }

    private void HandleSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        _selectedAthleteSlug = string.Empty;
        FilterAthletes();
        _showDropdown = true;
        _highlightedAthleteIndex = 0;
    }

    private void FilterAthletes()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredAthletes = [];
            return;
        }

        _filteredAthletes = _athletes
            .Where(a => !RegisteredAthletes.Contains(a.Slug ?? string.Empty, StringComparer.OrdinalIgnoreCase))
            .Where(a => a.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            .Take(10)
            .ToList();
    }

    private void SelectAthlete(AthleteSummary athlete)
    {
        _errorMessage = null;
        _selectedAthleteSlug = athlete.Slug ?? string.Empty;
        _searchText = athlete.Name;
        _showDropdown = false;
        _filteredAthletes = [];
    }

    private void HandleAthleteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            _highlightedAthleteIndex = Math.Min(_highlightedAthleteIndex + 1, _filteredAthletes.Count - 1);
            _preventDefaultOnAthleteInput = true;
        }
        else if (e.Key == "ArrowUp")
        {
            _highlightedAthleteIndex = Math.Max(_highlightedAthleteIndex - 1, 0);
            _preventDefaultOnAthleteInput = true;
        }
        else if (e.Key == "Enter")
        {
            if (_showDropdown && _filteredAthletes.Count > 0)
            {
                SelectAthlete(_filteredAthletes[_highlightedAthleteIndex]);
            }
            _preventDefaultOnAthleteInput = true;
        }
        else if (e.Key == "Escape")
        {
            _showDropdown = false;
            _preventDefaultOnAthleteInput = true;
        }
        else
        {
            _preventDefaultOnAthleteInput = false;
        }
    }

    private async Task HandleBlur()
    {
        await Task.Delay(200);
        _showDropdown = false;
    }

    private void HandleTeamSearchInput(ChangeEventArgs e)
    {
        _teamSearchText = e.Value?.ToString() ?? string.Empty;
        _selectedTeamId = null;
        FilterTeams();
        _showTeamDropdown = true;
        _highlightedTeamIndex = 0;
    }

    private void FilterTeams()
    {
        if (string.IsNullOrWhiteSpace(_teamSearchText))
        {
            _filteredTeams = [];
            return;
        }

        _filteredTeams = _teams
            .Where(t => t.Title.Contains(_teamSearchText, StringComparison.OrdinalIgnoreCase))
            .Take(10)
            .ToList();
    }

    private void SelectTeam(TeamOption team)
    {
        _selectedTeamId = team.Id;
        _teamSearchText = team.Title;
        _showTeamDropdown = false;
        _filteredTeams = [];
    }

    private async Task HandleTeamBlur()
    {
        await Task.Delay(200);
        _showTeamDropdown = false;
    }

    private void HandleTeamKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            _highlightedTeamIndex = Math.Min(_highlightedTeamIndex + 1, _filteredTeams.Count - 1);
            _preventDefaultOnTeamInput = true;
        }
        else if (e.Key == "ArrowUp")
        {
            _highlightedTeamIndex = Math.Max(_highlightedTeamIndex - 1, 0);
            _preventDefaultOnTeamInput = true;
        }
        else if (e.Key == "Enter")
        {
            if (_showTeamDropdown && _filteredTeams.Count > 0)
            {
                SelectTeam(_filteredTeams[_highlightedTeamIndex]);
            }
            _preventDefaultOnTeamInput = true;
        }
        else if (e.Key == "Escape")
        {
            _showTeamDropdown = false;
            _preventDefaultOnTeamInput = true;
        }
        else
        {
            _preventDefaultOnTeamInput = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (!IsFormValid)
        {
            return;
        }

        _errorMessage = null;

        try
        {
            AddParticipantCommand command = new(_selectedAthleteSlug, _bodyWeight, _selectedTeamId);
            HttpResponseMessage response = await HttpClient.PostAsJsonAsync(
                $"/meets/{MeetId}/participants", command);

            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                _errorMessage = "Keppandi er þegar skráður í þetta mót";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Villa kom upp. Reyndu aftur síðar.";
                return;
            }

            AddParticipantResponse? result = await response.Content
                .ReadFromJsonAsync<AddParticipantResponse>();

            if (result is not null)
            {
                await SaveAttempts(result.ParticipationId);
            }

            ResetForm();
            await OnParticipantAdded.InvokeAsync();
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
    }

    private async Task SaveAttempts(int participationId)
    {
        foreach (KeyValuePair<(Discipline Discipline, short Round), string> entry in _attemptValues)
        {
            if (string.IsNullOrWhiteSpace(entry.Value))
            {
                continue;
            }

            if (!decimal.TryParse(entry.Value, CultureInfo.InvariantCulture, out decimal weight) || weight == 0)
            {
                continue;
            }

            RecordAttemptCommand attemptCommand = new(Math.Abs(weight), weight > 0);
            await HttpClient.PutAsJsonAsync(
                $"/meets/{MeetId}/participants/{participationId}/attempts/{(int)entry.Key.Discipline}/{entry.Key.Round}",
                attemptCommand);
        }
    }

    private void ResetForm()
    {
        _searchText = string.Empty;
        _selectedAthleteSlug = string.Empty;
        _bodyWeight = 0;
        _errorMessage = null;
        _teamSearchText = string.Empty;
        _selectedTeamId = null;
        InitializeAttemptValues();
    }
}