@using KRAFT.Results.Contracts
@using KRAFT.Results.Contracts.Meets
@using KRAFT.Results.Web.Client.Components
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization

@inject HttpClient HttpClient
@inject IJSRuntime JS

<div class="p-card @(Participation.Disqualified ? "p-card-dq" : null)"
     style="@($"--grid-template: {DesktopGridTemplate}")">

    <div class="p-header-row">
        <div class="p-rank @_rankClass">
            @_rankDisplay
        </div>
        <div class="p-name-col">
            <NavLink class="p-name" href="@($"/athletes/{Participation.AthleteSlug}")">@Participation.Athlete</NavLink>
            <span class="p-meta">
                @_metaLine
                <AuthorizeView Roles="Admin">
                    <button class="btn-edit-weight"
                            aria-label="Breyta líkamsþyngd"
                            @onclick="ShowEditDialog">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                            <path d="m15 5 4 4"/>
                        </svg>
                    </button>
                    @if (IsAdmin)
                    {
                        <button class="btn-remove-participant"
                                aria-label="Fjarlægja keppanda"
                                @onclick="ShowRemoveDialog">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 6h18"/>
                                <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                <line x1="10" x2="10" y1="11" y2="17"/>
                                <line x1="14" x2="14" y1="11" y2="17"/>
                            </svg>
                        </button>
                    }
                </AuthorizeView>
            </span>
        </div>
        @if (ShowClub)
        {
            @if (!string.IsNullOrWhiteSpace(Participation.Club) && !string.IsNullOrWhiteSpace(Participation.ClubSlug))
            {
                <NavLink class="p-club" href="@($"/teams/{Participation.ClubSlug}")">@Participation.Club</NavLink>
            }
            else
            {
                <div class="p-club p-club-empty"></div>
            }
        }
    </div>

    <div class="p-attempts">
        @if (IsAdmin)
        {
            @foreach (Discipline disc in IncludedDisciplines.Keys
                .OrderBy(d => (byte)d))
            {
                <div class="p-disc-col">
                    <span class="p-disc-label">@disc.ToDisplayName()</span>
                    <div class="p-pills">
                        @for (short round = 1; round <= 3; round++)
                        {
                            short r = round;
                            Discipline d = disc;
                            MeetAttempt? attempt = Participation.Attempts
                                .FirstOrDefault(a => a.Discipline == d && a.Round == r);

                            MeetAttempt displayAttempt = _savedAttempts.TryGetValue((d, r), out (decimal W, bool G) saved)
                                ? new MeetAttempt(d, r, saved.W, saved.G, attempt?.IsRecord ?? false, attempt?.RecordAgeCategory)
                                : attempt ?? new MeetAttempt(d, r, 0, false, false);

                            @if (_editingAttempt.GetValueOrDefault((d, r)))
                            {
                                <input type="text"
                                       inputmode="decimal"
                                       class="inline-attempt-input"
                                       id="@GetInputId(d, r)"
                                       aria-label="@($"{disc.ToDisplayName()} lota {r}")"
                                       value="@_editValues.GetValueOrDefault((d, r), string.Empty)"
                                       @oninput="(e) => _editValues[(d, r)] = e.Value?.ToString() ?? string.Empty"
                                       @onblur="() => SaveAttempt(d, r)"
                                       @onkeydown="(e) => HandleAttemptKeyDown(e, d, r)"
                                       @onkeydown:stopPropagation />
                            }
                            else
                            {
                                <AttemptPill Attempt="displayAttempt"
                                             RecordContext="@BuildRecordContext(attempt)"
                                             OnClick="() => StartEdit(d, r, displayAttempt)" />
                            }

                            @if (_attemptErrors.TryGetValue((d, r), out string? err))
                            {
                                <span class="attempt-error">@err</span>
                            }
                        }
                    </div>
                </div>
            }
        }
        else
        {
            @foreach (Discipline disc in IncludedDisciplines.Keys.OrderBy(d => (byte)d))
            {
                <div class="p-disc-col">
                    <span class="p-disc-label">@disc.ToDisplayName()</span>
                    <div class="p-pills">
                        @for (short round = 1; round <= 3; round++)
                        {
                            short r = round;
                            Discipline d = disc;
                            MeetAttempt? attempt = Participation.Attempts
                                .FirstOrDefault(a => a.Discipline == d && a.Round == r);

                            @if (attempt is not null)
                            {
                                <AttemptPill Attempt="attempt"
                                             RecordContext="@BuildRecordContext(attempt)" />
                            }
                            else
                            {
                                <span class="pill pill-bad">–</span>
                            }
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="p-footer-row">
        <div class="p-total">
            <span class="p-footer-label">Samtala</span>
            @if (!Participation.Disqualified && DisplayTotal > 0)
            {
                @($"{DisplayTotal:F1}")
            }
            else if (!Participation.Disqualified)
            {
                <span>–</span>
            }
        </div>
        @if (ShowIpfPoints)
        {
            <div class="p-ipf">
                <span class="p-footer-label">IPF stig</span>
                @if (!Participation.Disqualified && DisplayIpfPoints > 0)
                {
                    @($"{DisplayIpfPoints:F2}")
                }
            </div>
        }
    </div>
</div>

<AuthorizeView Roles="Admin">
    <EditBodyWeightDialog @ref="_editDialog"
                          Id="@($"edit-weight-{Participation.ParticipationId}")"
                          AthleteName="@Participation.Athlete"
                          CurrentWeight="Participation.BodyWeight"
                          OnSave="HandleSaveWeight"
                          ErrorMessage="@_editErrorMessage"
                          IsLoading="_isSaving" />
</AuthorizeView>

<ConfirmDialog @ref="_removeDialog"
               Id="@($"remove-participant-{Participation.ParticipationId}")"
               Title="Fjarlægja keppanda"
               Message="@($"Ertu viss um að þú viljir fjarlægja {Participation.Athlete} úr þessu móti?")"
               ConfirmLabel="Fjarlægja"
               OnConfirm="HandleRemoveParticipant"
               ErrorMessage="@_removeErrorMessage"
               IsLoading="_isRemoving" />

@code {
    private EditBodyWeightDialog _editDialog = null!;
    private ConfirmDialog _removeDialog = null!;
    private bool _isSaving;
    private bool _isRemoving;
    private string? _editErrorMessage;
    private string? _removeErrorMessage;
    private readonly Dictionary<(Discipline, short), bool> _editingAttempt = [];
    private readonly Dictionary<(Discipline, short), string> _editValues = [];
    private (Discipline, short)? _pendingSelect;
    private readonly Dictionary<(Discipline, short), (decimal Weight, bool Good)> _savedAttempts = [];
    private readonly Dictionary<(Discipline, short), string> _attemptErrors = [];
    private MeetParticipation? _lastParticipation;
    private MeetParticipation? _freshParticipation;

    [Parameter, EditorRequired]
    public MeetParticipation Participation { get; init; } = null!;

    [Parameter, EditorRequired]
    public bool ShowIpfPoints { get; init; }

    [Parameter, EditorRequired]
    public bool ShowClub { get; init; }

    [Parameter, EditorRequired]
    public Dictionary<Discipline, bool> IncludedDisciplines { get; init; } = new();

    [Parameter, EditorRequired]
    public string DesktopGridTemplate { get; init; } = string.Empty;

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public EventCallback OnParticipantRemoved { get; set; }

    [Parameter]
    public EventCallback OnBodyWeightUpdated { get; set; }

    [Parameter]
    public EventCallback<string> OnSaveError { get; set; }

    private string _metaLine = string.Empty;
    private string _rankDisplay = string.Empty;
    private string _rankClass = string.Empty;

    private decimal DisplayTotal => _freshParticipation?.Total ?? Participation.Total;

    private decimal DisplayIpfPoints => _freshParticipation?.IpfPoints ?? Participation.IpfPoints;

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_lastParticipation, Participation))
        {
            _savedAttempts.Clear();
            if (_lastParticipation?.ParticipationId != Participation.ParticipationId)
            {
                _freshParticipation = null;
            }

            _lastParticipation = Participation;
        }

        RebuildMetaLine();

        if (Participation.Disqualified)
        {
            _rankDisplay = "–";
            _rankClass = string.Empty;
        }
        else
        {
            _rankDisplay = Participation.Rank switch
            {
                1 => "🥇",
                2 => "🥈",
                3 => "🥉",
                _ when Participation.Rank > 0 && Participation.Rank < int.MaxValue - 1 => Participation.Rank.ToString(),
                _ => "–",
            };

            _rankClass = Participation.Rank switch
            {
                1 or 2 or 3 => "rank-medal",
                _ => string.Empty,
            };
        }

    }

    private void RebuildMetaLine()
    {
        decimal bodyWeight = _freshParticipation?.BodyWeight ?? Participation.BodyWeight;
        List<string> metaParts = [Participation.YearOfBirth.ToString()];
        metaParts.Add($"{bodyWeight:F2} kg");
        _metaLine = string.Join(" · ", metaParts);
    }

    private string? BuildRecordContext(MeetAttempt? attempt)
    {
        if (attempt is null || !attempt.IsRecord || !attempt.IsGood)
        {
            return null;
        }

        string ageCategory = attempt.RecordAgeCategory ?? Participation.AgeCategory;
        return $"Met: {Participation.Gender} · {ageCategory} · {Participation.WeightCategory} kg";
    }

    private async Task RefreshParticipation()
    {
        try
        {
            MeetParticipation? fresh = await HttpClient.GetFromJsonAsync<MeetParticipation>(
                $"/meets/{Participation.MeetId}/participations/{Participation.ParticipationId}");
            if (fresh is not null)
            {
                _freshParticipation = fresh;
                RebuildMetaLine();
            }
        }
        catch (HttpRequestException)
        {
            // Ignore — stale data is acceptable
        }
    }

    private async Task ShowEditDialog()
    {
        _editErrorMessage = null;
        await _editDialog.ShowAsync();
    }

    private async Task HandleSaveWeight(decimal newWeight)
    {
        try
        {
            _isSaving = true;
            _editErrorMessage = null;

            UpdateBodyWeightCommand command = new(newWeight);
            HttpResponseMessage response = await HttpClient.PatchAsJsonAsync(
                $"/meets/{Participation.MeetId}/participations/{Participation.ParticipationId}",
                command);

            if (!response.IsSuccessStatusCode)
            {
                _editErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
                return;
            }

            await _editDialog.CloseAsync();
            await RefreshParticipation();
            await OnBodyWeightUpdated.InvokeAsync();
        }
        catch (HttpRequestException)
        {
            _editErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ShowRemoveDialog()
    {
        _removeErrorMessage = null;
        await _removeDialog.ShowAsync();
    }

    private async Task HandleRemoveParticipant()
    {
        try
        {
            _isRemoving = true;
            _removeErrorMessage = null;

            HttpResponseMessage response = await HttpClient.DeleteAsync(
                $"/meets/{Participation.MeetId}/participants/{Participation.ParticipationId}");

            if (!response.IsSuccessStatusCode)
            {
                _removeErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
                return;
            }

            await _removeDialog.CloseAsync();
            await OnParticipantRemoved.InvokeAsync();
        }
        catch (HttpRequestException)
        {
            _removeErrorMessage = "Villa kom upp. Reyndu aftur síðar.";
        }
        finally
        {
            _isRemoving = false;
        }
    }

    private async Task StartEdit(Discipline discipline, short round, MeetAttempt? attempt)
    {
        List<(Discipline, short)> currentlyEditing = _editingAttempt
            .Where(kv => kv.Value)
            .Select(kv => kv.Key)
            .ToList();

        foreach ((Discipline d, short r) in currentlyEditing)
        {
            await SaveAttempt(d, r);
        }

        _attemptErrors.Remove((discipline, round));
        _editingAttempt[(discipline, round)] = true;
        _pendingSelect = (discipline, round);

        if (attempt is not null && attempt.Weight > 0)
        {
            decimal signedWeight = attempt.IsGood ? attempt.Weight : -attempt.Weight;
            _editValues[(discipline, round)] = signedWeight.ToString("F1", CultureInfo.CurrentCulture);
        }
        else
        {
            _editValues[(discipline, round)] = string.Empty;
        }
    }

    private async Task SaveAttempt(Discipline discipline, short round)
    {
        if (!_editingAttempt.GetValueOrDefault((discipline, round)))
        {
            return;
        }

        _editingAttempt[(discipline, round)] = false;

        string value = _editValues.GetValueOrDefault((discipline, round), string.Empty);

        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        if (!decimal.TryParse(value, CultureInfo.CurrentCulture, out decimal weight) || weight == 0)
        {
            _attemptErrors[(discipline, round)] = "Ógilt gildi";
            return;
        }

        decimal absoluteWeight = Math.Abs(weight);

        if (!IsAttemptOrderValid(discipline, round, absoluteWeight))
        {
            _attemptErrors[(discipline, round)] = "Röng röð";
            return;
        }

        _attemptErrors.Remove((discipline, round));
        _savedAttempts[(discipline, round)] = (absoluteWeight, weight > 0);

        try
        {
            RecordAttemptCommand command = new(absoluteWeight, weight > 0);
            HttpResponseMessage response = await HttpClient.PutAsJsonAsync(
                $"/meets/{Participation.MeetId}/participants/{Participation.ParticipationId}/attempts/{(int)discipline}/{round}",
                command);

            if (!response.IsSuccessStatusCode)
            {
                _savedAttempts.Remove((discipline, round));
                await OnSaveError.InvokeAsync("Villa kom upp. Reyndu aftur.");
                return;
            }

            await RefreshParticipation();
            await OnBodyWeightUpdated.InvokeAsync();
        }
        catch (HttpRequestException)
        {
            _savedAttempts.Remove((discipline, round));
            await OnSaveError.InvokeAsync("Villa kom upp. Reyndu aftur.");
        }
    }

    private decimal GetEffectiveAttemptWeight(Discipline discipline, short round)
    {
        if (_savedAttempts.TryGetValue((discipline, round), out (decimal W, bool G) saved))
        {
            return saved.W;
        }

        MeetAttempt? attempt = Participation.Attempts
            .FirstOrDefault(a => a.Discipline == discipline && a.Round == round);
        return attempt?.Weight ?? 0m;
    }

    private bool IsAttemptOrderValid(Discipline discipline, short round, decimal absoluteWeight)
    {
        for (short r = 1; r <= 3; r++)
        {
            if (r == round)
            {
                continue;
            }

            decimal existing = GetEffectiveAttemptWeight(discipline, r);

            if (existing == 0)
            {
                continue;
            }

            if (r < round && existing > absoluteWeight)
            {
                return false;
            }

            if (r > round && existing < absoluteWeight)
            {
                return false;
            }
        }

        return true;
    }

    private async Task HandleAttemptKeyDown(KeyboardEventArgs e, Discipline discipline, short round)
    {
        if (e.Key == "Enter" || (e.Key == "Tab" && !e.ShiftKey))
        {
            await SaveAttempt(discipline, round);
            (Discipline nextDisc, short nextRound)? next = GetNextCell(discipline, round);
            if (next.HasValue)
            {
                MeetAttempt? nextAttempt = Participation.Attempts
                    .FirstOrDefault(a => a.Discipline == next.Value.nextDisc && a.Round == next.Value.nextRound);
                await StartEdit(next.Value.nextDisc, next.Value.nextRound, nextAttempt);
            }
        }
        else if (e.Key == "Tab" && e.ShiftKey)
        {
            await SaveAttempt(discipline, round);
            (Discipline prevDisc, short prevRound)? prev = GetPreviousCell(discipline, round);
            if (prev.HasValue)
            {
                MeetAttempt? prevAttempt = Participation.Attempts
                    .FirstOrDefault(a => a.Discipline == prev.Value.prevDisc && a.Round == prev.Value.prevRound);
                await StartEdit(prev.Value.prevDisc, prev.Value.prevRound, prevAttempt);
            }
        }
        else if (e.Key == "Escape")
        {
            _editValues[(discipline, round)] = string.Empty;
            _editingAttempt[(discipline, round)] = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingSelect.HasValue)
        {
            (Discipline d, short r) = _pendingSelect.Value;
            _pendingSelect = null;
            await JS.InvokeVoidAsync("Kraftresults.setupAttemptInput", GetInputId(d, r));
        }
    }

    private (Discipline, short)? GetPreviousCell(Discipline discipline, short round)
    {
        List<Discipline> disciplines = [.. IncludedDisciplines.Keys.OrderBy(d => (byte)d)];

        if (round > 1)
        {
            return (discipline, (short)(round - 1));
        }

        int discIndex = disciplines.IndexOf(discipline);
        if (discIndex > 0)
        {
            return (disciplines[discIndex - 1], 3);
        }

        return null;
    }

    private (Discipline, short)? GetNextCell(Discipline discipline, short round)
    {
        List<Discipline> disciplines = [.. IncludedDisciplines.Keys.OrderBy(d => (byte)d)];

        if (round < 3)
        {
            return (discipline, (short)(round + 1));
        }

        int discIndex = disciplines.IndexOf(discipline);
        if (discIndex < disciplines.Count - 1)
        {
            return (disciplines[discIndex + 1], 1);
        }

        return null;
    }

    private string GetInputId(Discipline discipline, short round) =>
        $"attempt-input-{Participation.ParticipationId}-{(int)discipline}-{round}";

}
